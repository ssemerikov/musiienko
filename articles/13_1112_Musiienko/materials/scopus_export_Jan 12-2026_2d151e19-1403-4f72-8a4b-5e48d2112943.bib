@ARTICLE{Severino-González2025386,
	author = {Severino-González, Pedro and Dote-Pardo, Jairo Stefano and Rojasbravo, Violeta and Calderón-Morales, Walter and Arévalo-Arévalo, Carlos and Trigos-Tapia, Pool Gianpiere and Sánchez-Rafael, Carlos and Alzamora, Sonia Antezana and Rebolledo-Aburto, Guipsy},
