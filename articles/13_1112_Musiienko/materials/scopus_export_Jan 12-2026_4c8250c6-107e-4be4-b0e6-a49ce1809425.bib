	abstract = {Soft skills are increasingly vital in the professional market due to growing specialization across industries, as well as trends in migration and globalization. Despite employers’ clear expectations regarding soft skills, these expectations are rarely assessed through systematic surveys. This study addresses this gap by providing an international perspective on current needs, with a focus on France, a partner in the Erasmus+ KA220-HED-9C51598F project, “Gamification Assets for Multisensorial Educative Tools in Language Learning using Co-Creation for Addressing Needs and Desires of Students Starting”. An online survey conducted between November 2022 and January 2023 explored the soft skills required in companies and challenges related to language use in professional contexts. The survey data were analyzed using descriptive statistics and qualitative coding for open-ended responses. The findings highlight evolving labor market demands for soft skills and offer insights into the educational landscape in France. This paper discusses the implications of these results for curriculum development and the design of targeted, effective language-learning programs tailored to contemporary workforce needs. © 2025, Slovenska Vzdelavacia Obstaravacia. All rights reserved.},
	author_keywords = {globalisation; internationalisation; labour market; soft skills; teaching foreign language},
	publisher = {Slovenska Vzdelavacia Obstaravacia},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0; All Open Access; Gold Open Access}
