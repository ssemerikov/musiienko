@ARTICLE{Waks1999303,
	author = {Waks, Leonard Joseph},
	title = {Reflective practice in the design studio and teacher education},
	year = {1999},
	journal = {Journal of Curriculum Studies},
	volume = {31},
	number = {3},
	pages = {303 - 316},
	doi = {10.1080/002202799183142},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-0343878343&doi=10.1080%2F002202799183142&partnerID=40&md5=80942f71a9cac74970689f1b31012491},
	abstract = {In Schon’s account, the distinguishing feature of professional work is its ‘designlike’ character. For Schon, professional training (including teacher preparation) involves engagement in design experiments in virtual worlds he calls ‘reflective practica’. Some teacher educators have developed models of teacher preparation following Schon’s guidelines. Others have expressed reservations about his framework. But there has not yet been adequate critical assessment of the conceptual fit between Schon’s framework and teacher preparation. This study contributes such an assessment. After providing a map through Schon’s system of ideas I proffer two conclusions. First, conventional school teaching is not ‘designlike’ in Schon’s sense. Second, teacher training cannot adequately be conducted ‘off-line’ in the virtual spaces Schon calls ‘reflective practica’. © 1999 Taylor & Francis Group LLC.},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 20}
}

