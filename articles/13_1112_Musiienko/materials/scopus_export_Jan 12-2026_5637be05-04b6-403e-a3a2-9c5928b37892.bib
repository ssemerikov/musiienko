@ARTICLE{Gaj19994591,
	author = {Gaj, Kris and Herr, Quentin P. and Adler, Victor and Brock, Darren K. and Friedman, Eby G. and Feldman, Marc J.},
	title = {Toward a systematic design methodology for large multigigahertz rapid single flux quantum circuits},
	year = {1999},
	journal = {IEEE Transactions on Applied Superconductivity},
