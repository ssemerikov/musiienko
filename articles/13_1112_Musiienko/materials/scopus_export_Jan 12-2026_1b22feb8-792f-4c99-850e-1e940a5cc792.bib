	author = {Totuk, Onat Halis and Selvi, Özgün and Akar, Samet},
	title = {Fused filament fabrication in CAD education: A closed-loop approach},
	year = {2025},
	journal = {International Journal of Mechanical Engineering Education},
	volume = {53},
	number = {1},
	pages = {167 - 188},
