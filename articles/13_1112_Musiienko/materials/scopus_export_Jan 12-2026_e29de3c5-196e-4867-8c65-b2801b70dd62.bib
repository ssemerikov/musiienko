	author = {Hocking, Viveka Turnbull and Brown, Valerie A. and Harris, John A.},
	title = {Tackling wicked problems through collective design},
	year = {2016},
	journal = {Intelligent Buildings International},
	volume = {8},
	number = {1},
	pages = {24 - 36},
	doi = {10.1080/17508975.2015.1058743},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-84939186780&doi=10.1080%2F17508975.2015.1058743&partnerID=40&md5=40047eafc8824ba283e77bb2d4d8b1bc},
	abstract = {Many of the concerns of intelligent architecture fit into the category of wicked problems, that is, problems whose resolution falls outside the current problem-solving capacity of the society that produced them. Wicked problems involve a diverse range of interests, defy a single definition, challenge the society that has produced them, and can have no final solution. Collective resolution of a wicked problem requires moving beyond the ruling constructions of knowledge to draw on all seven ways of understanding of which the human mind is capable. A contribution to architectural planning and design that addresses these conditions is the pattern language developed by Christopher Alexander. This paper explores the contribution of collective thinking and pattern language to planning and design that can meet the demands of transformational change. © 2015 Taylor & Francis.},
