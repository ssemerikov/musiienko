	note = {Cited by: 8}
}

@ARTICLE{Baldacchino2013343,
	author = {Baldacchino, John},
	title = {What creative industries? Instrumentalism, autonomy and the education of artists},
	year = {2013},
	journal = {International Journal of Education Through Art},
	volume = {9},
	number = {3},
	pages = {343 - 356},
	doi = {10.1386/eta.9.3.343_1},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-84887535952&doi=10.1386%2Feta.9.3.343_1&partnerID=40&md5=d364ca1e4b59cf54f0b71be99ca3f92b},
	abstract = {As the narrative of the Creative Industries becomes commonplace, arts institutions are increasingly expected to interface arts practice with business and enterprise. This article opens with a critique of the CBI's document 'First Steps' (2012), arguing how this minimizes the arts' role in schools. It then provides an analysis of two pedagogies: productivism and autonomism. Following the implications that emerge from the tension between productivism and autonomism in arts pedagogy, and reading these implications from within the contexts of the divergent and increasingly hybrid forms of contemporary art practices, this article then moves on to state that to argue for the legitimation of the arts by gathering what they do under the designation of the Creative Industries would amount to reifying art into an object of mere use, thus distorting both its productive and autonomist possibilities. © 2013 Intellect Ltd Article.},
	author_keywords = {Autonomy; CBI; Creative industries; Instrumentalism; Pedagogical aesthetics; Productivist aesthetic},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 22}
}

