@ARTICLE{Tibbitts202167,
	author = {Tibbitts, Susie and Ventura, Roberto},
	title = {Graphically speaking: Integrating graphic design with interior design studio and graphics coursework},
	year = {2021},
	journal = {International Journal of Design Education},
	volume = {16},
	number = {1},
	pages = {67 - 79},
	doi = {10.18848/2325-128X/CGP/v16i01/67-79},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85117013012&doi=10.18848%2F2325-128X%2FCGP%2Fv16i01%2F67-79&partnerID=40&md5=bc57db710bdc1d494876a2dd3d6716b7},
	abstract = {Historic examples reinforce the traditional connections between interior design and graphic design, yet scant evidence exists that interior design education values integrating graphic design into its body of knowledge. Lacking access to faculty or scholarship emphasizing graphic design fundamentals, interior design students base two-dimensional design decisions on uninformed rationales. With an explicit foundation in graphic design, interior design students could more critically engage the growing intersection of these two disciplines common in contemporary interiors practice. Educators at two schools addressed this schism by integrating graphic design content into existing interior design graphics and studio classes because of the synthetic nature of those courses. Instructors identified significant overlaps between graphic and interior design fundamentals and augmented their teaching with graphic design-specific exercises elaborating on typography, composition, communication and critique. Typography studies introduced typeface anatomy, pairing strategies, and type's expressive potential. Compositional studies introduced analytical methods for understanding two-dimensional spatial zones, which informed graphic design-intensive assignments focused on visual communication. Graphic design practitioners and academics provided critique, reinforced instruction and provided additional learning opportunities for students and faculty. After introducing graphic design learning activities into interior design studio and graphics courses, instructors noted beneficial changes in student work. Students organically integrated graphic design into studio work. A heightened awareness of and excitement about typography manifested itself in more sophisticated and ordered choices. Student confidence with graphic communication, especially with portfolio development, bolstered their post-graduation employment search. Additionally, students explored professional paths that bridged both disciplines, like environmental graphics, branding and exhibit design. © Common Ground Research Networks, Susie Tibbitts, Roberto Ventura, All Rights Reserved.},
	author_keywords = {Design Communication; Design Fundamentals; Graphic Design; Interior Design; Pedagogy},
	publisher = {Common Ground Research Networks},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 1}
}

@ARTICLE{Branch20211,
	author = {Branch, James and Parker, Christopher J. and Andrew Evans, Mark Andrew},
	title = {Do User Experience (UX) Design Courses Meet Industry’s Needs? Analysing UX Degrees and Job Adverts},
	year = {2021},
	journal = {Design Journal},
	volume = {24},
	number = {4},
	pages = {1 - 22},
	doi = {10.1080/14606925.2021.1930935},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85108272773&doi=10.1080%2F14606925.2021.1930935&partnerID=40&md5=cbd005300ce8e229ba51eef0903bd611},
	abstract = {With the recent growth in demand for skilled user experience (UX) practitioners, there has been a significant expansion of higher education UX degree courses. Yet, despite increasing educational provision, UX design industry figures criticize UX degree courses for not meeting industry’s needs. To examine the issue, this study asks: (1) What competencies are specified by UX degree courses? (2) How do UX and UX related degree courses’ competencies and employers’ requirements align? To answer these questions, the researchers analysed 93 programme and module specification documents for 34 UX, and UX related, degree courses and 50 job adverts for UX designers in the UK. The study concludes that UX, within formal education, is narrowly reliant on already established subjects and yet to mature into a holistic discipline. UX curricula are also developing in diverse ways across different institutions. Finally, the findings reveal that industry and academia have different priorities. The study underscores the need for further research into UX practice and pedagogy, cross-institutional cooperation, and enhanced connections with the communities of UX practice. © 2021 The Author(s). Published by Informa UK Limited, trading as Taylor & Francis Group.},
	author_keywords = {careers; design; employability; pedagogy; UX},
	publisher = {Taylor and Francis Ltd.},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 18; All Open Access; Green Accepted Open Access; Green Open Access; Hybrid Gold Open Access}
}

@ARTICLE{Loeffler202139,
	author = {Loeffler, Shane and Roth, Robert Emmett and Goring, Simon James and Myrbo, Amy E.},
