@ARTICLE{Sibley2025,
	author = {Sibley, Sean and Sabegh, Nima Sajedi and Herbert, Valerie M.},
	title = {Using unfolding OSCEs across a graduate nursing curriculum to implement competency-based education assessment},
	year = {2025},
	journal = {Clinical Simulation in Nursing},
	volume = {105},
	pages = {},
	doi = {10.1016/j.ecns.2025.101771},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105009604235&doi=10.1016%2Fj.ecns.2025.101771&partnerID=40&md5=7de0691e2eb5d5a971776484a34f5ab9},
	abstract = {Aim: This study investigated the relationship between learner reactions and objective learning, and using scaffolded objective structured clinical examinations (OSCE) to demonstrate competency mastery. Background: Simulation-based education that employs best practices provides a mechanism for teaching and learning in a competency-based education paradigm. Evidence-informed practices specifically in graduate nursing education are lacking. Methods: A quasi-experimental design assessed learner reactions and objective learning outcomes of graduate nursing students. Results: While student satisfaction and self-confidence in learning were strongly related to each other, they showed only weak correlations with OSCE grades. Patient-centered competency grades increased across OSCE experiences. Conclusion: To promote learning, faculty should use best-practices to execute simulation in graduate education. Scaffolded OSCEs can demonstrate progressive competency mastery. © 2025},
	author_keywords = {Competency; Family; Graduate education; Nurse practitioner; Objective structured clinical examinations; Simulation},
	publisher = {Elsevier Inc.},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0}
}

@ARTICLE{Becker2025,
	author = {Becker, Emily S. and Grant, Michael and Sy, Hannah and Bering, Sean and Taylor, Sally Marie},
	title = {Leadership in Health Care: A Comparison With Leadership Development Best Practices},
	year = {2025},
	journal = {Journal of Physical Therapy Education},
	pages = {},
	doi = {10.1097/JTE.0000000000000423},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105008560688&doi=10.1097%2FJTE.0000000000000423&partnerID=40&md5=3098bdc6764d3d5c239ddd99aadb3238},
	abstract = {Background and Purpose. Effective leadership is essential in today’s health care environment. To date, no study exists identifying the best practices for Leader Development (LD) within the physical therapy profession, nor has there been a published review of existing leadership curricula against health care industry best practices. The purpose of this project is to (1) design and develop a comprehensive checklist to guide physical therapy educators when developing and evaluating LD curricula and (2) to implement and evaluate this checklist by reviewing a current Leadership Development Program (LDP) within the physical therapy profession. Method/Model Description and Evaluation. Applying the Analysis, Design, Development, Implementation, and Evaluation (ADDIE) model of instructional design, the researchers identified a systematic review of LDPs and a meta-analysis as the most comprehensive sources for mapping 12 best practices indicators of LDP curriculum into a design and development of a comprehensive LDP best practices checklist based upon Kern’s 6 Step to Curriculum Development conceptual framework. The LDP best practices criterion checklist was then implemented and evaluated by applying it to an existing national LDP within the physical therapy profession. Outcomes. When applying the LDP best practices checklist, consensus was achieved among 3 independent reviewers. The LDP best practices checklist was sensitive in identifying when the LD curriculum met the best practice indicator and when there were areas for improvement in each of the 12 best practice criteria. Discussion and Conclusion. Physical therapy educational programs and health care organizations should consider using this LDP best practices criterion checklist to guide the development, design, and implementation of their LDP. By adhering to contemporary best practices in LDPs, programs can improve their effectiveness in achieving their intended outcomes. © © 2025 Academy of Physical Therapy Education, APTA.},
	author_keywords = {Leadership; Leadership curriculum; Leadership education and development},
	publisher = {Lippincott Williams and Wilkins},
	type = {Article},
	publication_stage = {aip},
	source = {Scopus},
	note = {Cited by: 0}
}

