@article{ WOS:001631848500003,
Author = {Su, Zhao and Shen, Jun and Zhou, Qingguo and Yong, Binbin},
Title = {Deep-Learning-Empowered Detection of Large-Language-Model-Based
   Generative Content in Educational Tasks},
Journal = {IEEE TRANSACTIONS ON LEARNING TECHNOLOGIES},
Year = {2025},
Volume = {18},
Pages = {1036-1047},
Abstract = {The rapid adoption of large language models (LLMs), such as ChatGPT, in
   education has intensified the need to differentiate artificial
   intelligence (AI)-generated from human-authored student work. This study
   proposes an intelligence augmentation (IA) framework that evaluates
   algorithmic performance while incorporating a human-in-the-loop
   mechanism for practical classroom deployment. Leveraging a comprehensive
   multitask dataset that spans article generation, text paraphrasing, and
   code generation, we conduct a systematic comparison between traditional
   machine learning and deep learning models. Beyond benchmark evaluations,
   the proposed approach is further validated using authentic classroom
   data, achieving up to 85\% detection accuracy-significantly surpassing
   conventional algorithms and state-of-the-art zero-shot baselines. The
   results present the first multitask evaluation of generated-text
   detection within an IA framework, demonstrating the broad adaptability
   of both classical machine learning and deep learning algorithms across
   educational scenarios. These findings offer empirical evidence and
   actionable insights for developing trustworthy IA systems that
   strengthen academic integrity in AI-assisted learning environments.},
