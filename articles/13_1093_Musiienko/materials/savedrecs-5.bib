@article{ WOS:001396258300002,
Author = {Shahzad, Tariq and Mazhar, Tehseen and Tariq, Muhammad Usman and Ahmad,
   Wasim and Ouahada, Khmaies and Hamam, Habib},
Title = {A comprehensive review of large language models: issues and solutions in
   learning environments},
