Year = {2024},
Volume = {1285},
Pages = {140-150},
Note = {20th Chinese Intelligent Systems Conference, Guilin, PEOPLES R CHINA,
   OCT 26-27, 2024},
Abstract = {In recent years, there has been a notable increase in academic interest
   surrounding the utilization of large language models in the development
   of intelligent systems, driven by the rapid advancements in the
   capabilities of these language models. The primary objective of this
   endeavor is to explore innovative avenues for human-machine interaction
   and to propel intelligent technology towards the realm of embodied
   intelligence. This survey conducts a detailed analysis of the
   integration of large language models in intelligent interactions, with a
   specific focus on their state-of-the-art applications in the field of
   desktop robotic arms, household robots, and autonomous driving. The aim
   of this review is to provide the academic and industrial communities
   with a comprehensive understanding of the implementation of large
   language models in intelligent interaction. Additionally, we discuss the
   challenges and opportunities in this field with the intention of
   promoting continuous progress and innovation in intelligent interaction
   technologies.},
