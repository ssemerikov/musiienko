@inproceedings{ WOS:001435925400007,
Author = {Agyemang, Alex and Schlippe, Tim},
Editor = {Gerber, A and Maritz, J and Pillay, AW},
Title = {AI in Education: An Analysis of Large Language Models for Twi Automatic
   Short Answer Grading},
Booktitle = {ARTIFICIAL INTELLIGENCE RESEARCH, SACAIR 2024},
