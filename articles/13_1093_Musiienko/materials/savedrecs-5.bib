Title = {Scalable Patent Analysis Using Function Calling with Local Large
   Language Models},
Booktitle = {PRACTICE AND EXPERIENCE IN ADVANCED RESEARCH COMPUTING 2025, PEARC 2025},
Year = {2025},
Note = {2025 Practice and Experience in Advanced Research Computing
   Conference-PEARC, Columbus, OH, JUL 20-24, 2025},
Organization = {Association for Computing Machinery},
Abstract = {User requests often foment technological innovation, prompting
   transformative change across research and functional areas. At Arizona
   State University, a collaboration with their intellectual property
   management services led to the development of an automated tool that
   addresses the growing need for efficient patent classification and
   analysis. The system leverages large language models integrated with
   function calling to retrieve, clean, and analyze patent data from the US
   Patent and Trademark Office data portal. Key functionalities include
   extracting university-assigned patents, classifying them using a
   streamlined version of the official code hierarchy, and executing
   targeted queries such as retrieving detailed patent information or
   identifying patents related to specific subject matters. This work
   contributes to more efficient patent management processes and serves as
   a blueprint for applying similar methodologies to related problems. This
   approach combines conventional data analysis with dynamic function
   calling, mitigating common artificial intelligence challenges such as
   hallucinations and providing accurate outputs.},
