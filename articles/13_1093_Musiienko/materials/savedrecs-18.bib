@article{ WOS:001112651200004,
Author = {Theimer, Sarah},
Title = {Using Threshold Concepts from Multiple Disciplines to Inform Cataloger
   Training},
Journal = {TECHNICAL SERVICES QUARTERLY},
Year = {2023},
Volume = {40},
Number = {4},
Pages = {274-289},
Month = {OCT 2},
Abstract = {Threshold concepts are foundational ideas that shape how learners
   understand a particular subject, without a firm grasp on these concepts,
   it is difficult for learning to progress. In librarianship, threshold
   concepts have not been identified for the area of cataloging. This
   article identifies three related areas with applicable threshold
   concepts: information literacy, public history, and creative writing.
   The study applies threshold concepts to cataloging training topics and
   identifies training improvements.},
