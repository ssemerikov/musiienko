@article{ WOS:000631044700001,
Author = {Derias, Nardin and Loftus, Stephen and Kamel-ElSayed, Suzan},
Title = {Threshold Concepts in Preclinical Medical Education: Students'
   Perceptions},
Journal = {MEDICAL SCIENCE EDUCATOR},
Year = {2021},
Volume = {31},
Number = {2},
Pages = {917-921},
Month = {APR},
Abstract = {Threshold concepts are those ideas that learners often find difficult,
   but must understand in order to master a discipline. Nearly all research
   into threshold concepts has been from the perspective of teachers. We
   argue that the students' perspectives can also be helpful. In this
   commentary, we explore this issue and inform the debate by drawing on
   insights from a pilot study in which medical students articulated their
   own views on what constituted threshold concepts from recent learning
   experiences in physiology. Combining insights, from teachers and
   students, into candidate threshold concepts could be used to improve the
   medical curriculum.},
