@article{ WOS:000497715400001,
Author = {Reeping, David},
Title = {Threshold concepts as `jewels of the curriculum': rare as diamonds or
   plentiful as cubic zirconia?},
Journal = {INTERNATIONAL JOURNAL FOR ACADEMIC DEVELOPMENT},
Year = {2020},
Volume = {25},
Number = {1, SI},
Pages = {58-70},
Month = {JAN 2},
Abstract = {The framework of threshold concepts has been used across several
   disciplines in higher education. Although the literature surrounding the
   identification of threshold concepts and their nature has flourished,
   their conceptualization has seemingly diverged across disciplinary
   lines, which should be recognized by educational developers who work
   with multiple disciplines. Inspired by a failed implementation of one
   framing of threshold concepts in Engineering, this article compares the
   conceptualization of threshold concepts in Engineering with their
   framing in Writing Studies and Information Literacy by drawing on
   Bernstein's notion of knowledge structures. Recommendations for
   educational developers are provided and situated within the framework of
   `ways of thinking and practising' (WTP).},
