Number = {1},
Pages = {1-13},
Abstract = {Threshold concepts and learning outcomes represent two different ways of
   thinking about teaching and learning. Finding a way to translate between
   the two is necessary for librarians who may wish to use concepts from
   the Framework for Information Literacy to shape their instruction. The
