@article{ WOS:001240313200001,
Author = {Dumitru, Adelin-Costin},
Title = {Threshold Conceptions of Harm and Non-identity: Sketching a
   Sufficientarian Proposal},
Journal = {ETHICAL PERSPECTIVES},
Year = {2023},
Volume = {30},
Number = {2},
Month = {JUN},
Abstract = {This article defends the distinct yet related ideas that future
   individuals can be harmed, that they have rights, and that we have
   correlative obligations towards those individuals. I argue that two of
   the main ideas usually considered to disallow the possibility of harm to
   future generations - the nonidentity problem and the absence of
   reciprocity between non -overlapping generations - share a similar
   structure and should be replaced by subject -centered approaches. I then
