@article{ WOS:000305534900006,
Author = {Yip, Jeffrey and Raelin, Joseph A.},
Title = {Threshold concepts and modalities for teaching leadership practice},
Journal = {MANAGEMENT LEARNING},
Year = {2012},
Volume = {43},
Number = {3},
Pages = {333-354},
Month = {JUL},
Abstract = {Can the teaching of leadership transform practice? What concepts and
   modalities are best suited to do so? This article builds on Meyer and
   Land's (2003) theory of threshold concepts to examine how students learn
   and experience leadership as a complex and multi-faceted practice.
   Threshold concepts are conceptual gateways, opening up new and
   previously inaccessible ways of thinking about a field. In an
   ethnographic account using participant observation, analysis of student
   papers, and in-depth interviews, the authors identified two threshold
   concepts that had a transformational impact on students: (1) situational
   leadership and (2) shared leadership. In addition, they found three
   modalities that supported the learning of threshold concepts: (1)
   variation, (2) enactment, and (3) reflection. The article concludes by
   citing the broader implications for the research and teaching of
   leadership practice.},
