@inproceedings{ WOS:000664182600191,
Author = {Hendrawati, R. and Mulyani, S. and Wiji, W.},
Book-Group-Author = {IOP},
Title = {A review for threshold concept identification methods in science},
Booktitle = {INTERNATIONAL CONFERENCE ON MATHEMATICS AND SCIENCE EDUCATION (ICMSCE)
   2020},
Series = {Journal of Physics Conference Series},
Year = {2021},
Volume = {1806},
Note = {International Conference on Mathematics and Science Education (ICMScE),
   ELECTR NETWORK, JUL 14-15, 2020},
Abstract = {The research of threshold concept has been vastly developed in various
   discipline including in the field of science during the last two
   decades. This causes the method to identify threshold concept increases
   in its variety. This research attempts to provide a general description
   of several methods used to identify the threshold concept in science.
   Method used in this research is document analysis method, which analyzes
   published articles and focuses on threshold concept identification
   method in science. Based on article analysis, it is obtained that the
   most often used method in threshold concept identification researches is
   interview, followed by survey, focus-group discussion, content analysis,
   test, workshop, concept maps and quiz. Therefore, researchers should
   have a good background knowledge regarding various method used in
   threshold concept research, so they can choose which method that would
   be effective and give the most optimal result for their own research.},
