Year = {2025},
Volume = {1544},
Pages = {103-113},
Note = {16th International Conference on Robotics in Education-RIE-Annual,
   Thessaloniki, GREECE, APR 23-25, 2025},
Abstract = {In this article, we examine four different approaches to the
   implementation of robotics projects. We look at monodisciplinary,
   interdisciplinary and interprofessional approaches as well as the use of
   living labs against the background of skill development in students. We
   use the current Future Skill Framework, which comprises four skill
   areas: technological skills, digital key skills, classical and
   transformative skills. With the help of project examples, we explain the
   different project approaches and evaluate them using the skills set of
   the Future Skill Framework.},
