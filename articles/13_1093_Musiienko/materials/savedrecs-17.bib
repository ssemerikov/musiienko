@inproceedings{ WOS:001174354000035,
Author = {Iyengar, Arun and Kundu, Ashish},
Book-Group-Author = {IEEE},
Title = {Large Language Models and Computer Security},
Booktitle = {2023 5TH IEEE INTERNATIONAL CONFERENCE ON TRUST, PRIVACY AND SECURITY IN
   INTELLIGENT SYSTEMS AND APPLICATIONS, TPS-ISA},
Year = {2023},
Pages = {307-313},
Note = {5th IEEE International Conference on Trust, Privacy and Security in
   Intelligent Systems and Applications (TPS-ISA), Atlanta, GA, NOV 01-03,
   2023},
Organization = {IEEE; IEEE Comp Soc},
Abstract = {Large language models (LLMs) are having a significant impact in many
   different fields. Security and privacy issues related to LLMs are of
   paramount importance. LLMs can be used to defend against cyberattacks
   and thwart attackers. LLMs can enhance computer security in several ways
   including identifying phishing attacks, identifying malware, analyzing
   incident reports from security breaches, determining vulnerability to
   attacks, analzying log information, and providing valuable information,
   education, and training materials. However, large language models can
   also be used by malicious parties to enhance cyberattacks. This paper
   looks at how LLMs can be used by both defenders and attackers. We also
   examine attacks on large language models which have been deployed to
   cause LLMs to output harmful information.},
Publisher = {IEEE},
