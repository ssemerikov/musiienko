@inproceedings{ WOS:001159735100002,
Author = {Kouzelis, Lazaros Rafail and Spantidi, Ourania},
Editor = {Bebis, G and Ghiasi, G and Fang, Y and Sharf, A and Dong, Y and Weaver, C and Leo, Z and LaViola, JJ and Kohli, L},
Title = {Synthesizing Play-Ready VR Scenes with Natural Language Prompts Through
   GPT API},
Booktitle = {ADVANCES IN VISUAL COMPUTING, ISVC 2023, PT II},
Series = {Lecture Notes in Computer Science},
Year = {2023},
Volume = {14362},
Pages = {15-26},
Note = {18th International Symposium on Visual Computing (ISVC), NV, OCT 16-18,
   2023},
Abstract = {In visual computing, 3D scene generation stands as a crucial component,
   offering applications in various fields such as gaming, virtual reality
   (VR), and architectural visualization. Creating realistic and versatile
   virtual environments, however, poses significant challenges. This work
   presents a novel methodology that leverages the capabilities of a widely
   adopted large language model (LLM) to address these challenges. Our
   approach utilizes the GPT API to interpret natural language prompts and
   generate detailed, VR-ready scenes within Unity3D. Our work is also
   inherently scalable, since the model accepts any database of 3D objects
   with minimal prior configuration. The effectiveness of the proposed
   system is demonstrated through a series of case studies, revealing its
   potential to generate diverse and functional virtual spaces.},
