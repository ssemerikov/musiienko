@article{ WOS:001160227000001,
Author = {Lai, Man-Chi and Lin, Yu-Feng and Wang, Sheng-Wei and Shih, Ching-Hsiang},
Title = {Applying Smartphone Vibration and Visual Text Prompt Functions to Reduce
   Hyperactive/Impulsive Behaviors of Students With ADHD in Class},
Journal = {JOURNAL OF SPECIAL EDUCATION TECHNOLOGY},
Year = {2024},
Volume = {39},
Number = {4},
Pages = {491-499},
Month = {DEC},
Abstract = {This study investigated the effectiveness of applying a smartphone to
   reduce the hyperactive/impulsive behaviors of 3 students with attention
   deficit hyperactivity disorder (ADHD) in class. A smartphone that can
   simultaneously provide vibration and visual text prompts was adopted in
   this study to remind the participants when they exhibited
   hyperactive/impulsive behaviors. This study adopted the multiple
   baseline design across subjects under the broader rubric of the
   single-subject research design, including 2 baseline phases and 2
   intervention phases. The results show that the time spent engaged in
   target behaviors decreased for participants during the intervention
   phases, compared to the baseline phases. The findings show that applying
   the vibration and visual text prompts of a smartphone is a feasible
   prompting strategy to assist students with ADHD to reduce their
   hyperactive/impulsive behaviors in class.},
