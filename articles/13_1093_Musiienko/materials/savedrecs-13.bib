@article{ WOS:001565151300001,
Author = {Xu, Luo and Han, Delong and Li, Gang and Zhou, Mingle and Wan, Jin and
   Li, Min},
Title = {Multimodal feature cooperative refinement for few-shot anomaly detection},
Journal = {ADVANCED ENGINEERING INFORMATICS},
Year = {2025},
Volume = {68},
Number = {C},
Month = {NOV},
Abstract = {Recently, vision-language models (VLMs) have significantly improved
   few-shot anomaly detection (FSAD) performance. However, existing methods
   lack the guidance of image semantics in text prompt construction,
   leading to imprecise text semantic prompt. Additionally, they fail to
   fully leverage the comprehensive representation of image intrinsic
   features, e.g., frequency features, resulting in inferior detection. To
   address these issues, we propose a novel FSAD framework based on
   multimodal feature collaborative refinement, aimed at producing refined
   text prompt and deep image feature representation for superior detection
   results. Specifically, we design a text prompt joint refinement (TPJR)
   mechanism, which includes self-driven text refinement and image-guided
   text refinement to enhance the text prompts' ability to describe image
   semantics. Furthermore, we design a frequency feature enhancement (FFE)
   module, which employs frequency separable convolution to capture
   high-frequency details and low-frequency features to enrich spatial
   feature representations. Finally, we incorporate decision-level dynamic
   fusion, which adaptively integrates detection results guided by
   different domains. In the 4-shot, extensive experiments on the MVTec-AD
   and VisA datasets demonstrate that our approach outperforms
   state-of-the-art methods in both image-level and pixel-level anomaly
   detection, achieving superior FSAD performance with AUROC of 94.8\% for
   anomaly classification, 98.0\% for anomaly segmentation, and a PRO of
   94.2\% on the VisA.},
