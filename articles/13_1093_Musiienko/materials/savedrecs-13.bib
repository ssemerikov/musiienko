@article{ WOS:001393340500001,
Author = {Yu, Zhenbo and Jin, Jian and Zhao, Jinhan and Fu, Zhenyong and Yang,
   Jian},
Title = {TtfDiffusion: Training-free and text-free image editing in diffusion
   models with structural and semantic disentanglement},
Journal = {NEUROCOMPUTING},
Year = {2025},
Volume = {619},
Month = {FEB 28},
Abstract = {Diffusion models achieve outstanding performance in various domains,
   particularly in the field of controlled image editing. Despite their
   great success, these models typically require both fine-tuning and the
   use of edited text prompts as conditions. However, fine-tuning diffusion
   models is highly time-consuming, and suitable edited text prompts may
   not be readily available or easy to devise in specific domains such as
   art, fashion, or specialized fields like medicine. To address this
   issue, we present our gradient-based method called TtfDiffusion, which
   is both t raining-free and t ext-free. This method enables efficient and
   effective semantic control using frozen pre-trained DDMs, eliminating
   the need for additional training and edited text prompts. Our method
   efficiently uncovers disentangled directions to separate the structure
   and semantics of images within the h-space of frozen pre-trained
   diffusion models during the denoising process, significantly enhancing
   image editing performance. Moreover, our method can improve images with
   poor original generation quality while editing semantics. It is
   applicable to various architectures, including DDPM, Stable
   Diffusion-v1.5, and Stable Diffusion-v2.1, and to datasets such as
   CelebA-HQ, LSUN-church, and LSUN-bedroom.},
