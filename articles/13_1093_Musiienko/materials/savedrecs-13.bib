@article{ WOS:001562045200001,
Author = {Zhao, Ziheng and Zhang, Yao and Wu, Chaoyi and Zhang, Xiaoman and Zhou,
   Xiao and Zhang, Ya and Wang, Yanfeng and Xie, Weidi},
Title = {Large-vocabulary segmentation for medical images with text prompts},
