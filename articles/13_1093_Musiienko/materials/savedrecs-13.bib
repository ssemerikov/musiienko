@inproceedings{ WOS:001556264700003,
Author = {Wang, Zhengyang and Jin, Hao and Zhang, Ye and Xie, Haoran},
Book-Group-Author = {IEEE COMPUTER SOC},
Title = {Multi-Story Building Image Generation Using Retrieval Augmented
   Diffusion Models},
Booktitle = {2025 NICOGRAPH INTERNATIONAL, NICOINT},
Year = {2025},
Pages = {17-22},
Note = {2025 International Conference on Nicograph International-NICOInt,
   Kanazawa, JAPAN, JUN 19-21, 2025},
Organization = {Society for Art and Science},
Abstract = {Despite recent advances in text-to-image generation greatly improving
   image quality, there is a growing demand for specifying image details
   through text prompts. Especially for building image generation, current
   models struggle with accurately controlling the number of floors due to
   the lack of fine-grained training data that explicitly associates text
   prompts with precise architectural attributes. To address this
   challenge, we propose a retrieval-augmented image generation framework
   for generating multi-story building image with precise floorcount
   control, leveraging a retrieval augmented text-to-image diffusion model.
   In the initial phase, we adopt latent diffusion model to generate a
   building image, which serves as the source of stylistic features for
   subsequent processes. Subsequently, the number of floors specified in
   the text prompt is utilized to retrieve the consistent image from a
   building image database. The style image and the retrieved building
   structure serve as conditioning inputs for the latent diffusion model to
   generate building images with the specified number of floors and styles.
   Our proposed framework enables accurate control over the number of
   floors in building image synthesis based on text-to-image diffusion
   models. We demonstrate the robustness and scalability of our proposed
   framework in generating building images with the specific number of
   floors from the input text prompts.},
