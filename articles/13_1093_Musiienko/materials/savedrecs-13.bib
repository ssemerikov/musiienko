Title = {SegAnimeChara: Segmenting Anime Characters Generated by AI},
Booktitle = {PROCEEDINGS OF SIGGRAPH 2023 POSTERS, SIGGRAPH 2023},
Year = {2023},
Note = {SIGGRAPH Meeting, Los Angeles, CA, AUG 06-10, 2023},
Organization = {ACM SIGGRAPH},
Abstract = {This work introduces SegAnimeChara, a novel system of transforming
   AI-generated anime images into game characters while retaining unique
   features. Using volume-based body pose segmentation, SegAnimeChara can
   efficiently, zero-shot, segment body parts from generative images based
