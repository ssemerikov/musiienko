@inproceedings{ WOS:001403057600018,
Author = {Qu, Zhen and Tao, Xian and Prasad, Mukesh and Shen, Fei and Zhang,
   Zhengtao and Gong, Xinyi and Ding, Guiguang},
Editor = {Leonardis, A and Ricci, E and Roth, S and Russakovsky, O and Sattler, T and Varol, G},
Title = {VCP-CLIP: A Visual Context Prompting Model for Zero-Shot Anomaly
   Segmentation},
Booktitle = {COMPUTER VISION - ECCV 2024, PT LXIX},
Series = {Lecture Notes in Computer Science},
Year = {2025},
Volume = {15127},
Pages = {301-317},
Note = {18th European Conference on Computer Vision (ECCV), Milan, ITALY, SEP
   29-OCT 04, 2024},
Organization = {AIM Group},
Abstract = {Recently, large-scale vision-language models such as CLIP have
   demonstrated immense potential in zero-shot anomaly segmentation (ZSAS)
   task, utilizing a unified model to directly detect anomalies on any
   unseen product with painstakingly crafted text prompts. However,
   existing methods often assume that the product category to be inspected
   is known, thus setting product-specific text prompts, which is difficult
   to achieve in the data privacy scenarios. Moreover, even the same type
   of product exhibits significant differences due to specific components
   and variations in the production process, posing significant challenges
   to the design of text prompts. In this end, we propose a visual context
   prompting model (VCP-CLIP) for ZSAS task based on CLIP. The insight
   behind VCP-CLIP is to employ visual context prompting to activate CLIP's
   anomalous semantic perception ability. In specific, we first design a
   Pre-VCP module to embed global visual information into the text prompt,
   thus eliminating the necessity for product-specific prompts. Then, we
   propose a novel Post-VCP module, that adjusts the text embeddings
   utilizing the fine-grained features of the images. In extensive
   experiments conducted on 10 real-world industrial anomaly segmentation
   datasets, VCP-CLIP achieved state-of-the-art performance in ZSAS task.
   The code is available at https://github.com/xiaozhen228/VCP-CLIP.},
Publisher = {SPRINGER INTERNATIONAL PUBLISHING AG},
Address = {GEWERBESTRASSE 11, CHAM, CH-6330, SWITZERLAND},
Type = {Proceedings Paper},
Language = {English},
Affiliation = {Tao, X (Corresponding Author), Chinese Acad Sci, Inst Automat, CAS Engn Lab Intelligent Ind Vis, Beijing, Peoples R China.
   Tao, X (Corresponding Author), Univ Chinese Acad Sci, Beijing, Peoples R China.
   Tao, X (Corresponding Author), CASI Vis Technol Co Ltd, Luoyang, Peoples R China.
   Qu, Zhen; Tao, Xian; Shen, Fei; Zhang, Zhengtao, Chinese Acad Sci, Inst Automat, CAS Engn Lab Intelligent Ind Vis, Beijing, Peoples R China.
   Qu, Zhen; Tao, Xian; Shen, Fei; Zhang, Zhengtao, Univ Chinese Acad Sci, Beijing, Peoples R China.
   Tao, Xian; Shen, Fei; Zhang, Zhengtao, CASI Vis Technol Co Ltd, Luoyang, Peoples R China.
