@article{ WOS:001451203200001,
Author = {Hong, Y. J. and Park, S. and Ha, S. and Kang, J. -y. and Koo, S.},
Title = {Design characteristics, preferences, and satisfaction toward virtual
   fashion using augmented reality},
Journal = {INTERNATIONAL JOURNAL OF FASHION DESIGN TECHNOLOGY AND EDUCATION},
Year = {2025},
Month = {2025 MAR 25},
Abstract = {This study aimed to understand the design characteristics and consumers'
   preferences and satisfaction of virtual fashion to provide guidelines
   for developing AR-based virtual fashion products. A total of 171 virtual
   fashion images were analyzed, followed by a quantitative survey on the
   preferences and purchase intentions of 305 participants living in the
   U.S. to investigate whether there are differences among subgroups. Ten
   virtual clothing designs were generated with AI-based software based on
   the survey results. A second survey involving 322 participants evaluated
   satisfaction and purchase intention toward the developed virtual
   clothing. This research defined the design characteristics of each
   design element of the purchased virtual clothing and identified consumer
   preferences regarding these design elements and analyzed consumer
   satisfaction and purchase intention toward the developed virtual
   clothing, including sub-group differences. The results of this study can
   help designers when developing virtual clothing with AR technology.},
