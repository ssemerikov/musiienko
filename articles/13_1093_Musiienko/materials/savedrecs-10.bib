@article{ WOS:001513165800001,
Author = {Ryu, Chaehi and Lee, Yoon Kyung},
Title = {Effective Fashion Design Collection Implementation with Generative AI:
   ChatGPT and Dall-E},
Journal = {CLOTHING AND TEXTILES RESEARCH JOURNAL},
Year = {2026},
Volume = {44},
Number = {1, SI},
Pages = {125-140},
Month = {JAN},
Abstract = {This study explored how ChatGPT, a natural language processing
   artificial intelligence (AI) technology, can be utilized in the complex,
   diverse, and creative field of fashion design. This study aimed to
   develop effective prompts that can enable designers to efficiently
   utilize OpenAI. The study also explored how ChatGPT can be used to
   improve the efficiency of seasonal trend analysis and seasonal
   collection design creation. First, the authors analyzed fashion trends
   and fashion collection data from x to September 2021 using ChatGPT-3.5
   and ChatGPT-4. Based on the results, the authors predicted fashion
   design trends for 2024 fall/winter men's fashion and created a 2024
   fall/winter men's fashion collection using DALL-E 3. Finally, the
   authors compared the results developed with OpenAI to fashion trend data
   provided by real-world trend companies to assess accuracy and verify
   objectivity.},
