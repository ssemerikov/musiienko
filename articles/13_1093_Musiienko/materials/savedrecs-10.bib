@inproceedings{ WOS:001553905700012,
Author = {Chen, Lijian and Zhao, Yuanfang},
Editor = {Rau, PLP},
Title = {A New Paradigm of Apparel Design Path in the Human-Machine Collaborative
   Model},
Booktitle = {CROSS-CULTURAL DESIGN, CCD 2025, PT IV},
Series = {Lecture Notes in Computer Science},
Year = {2025},
Volume = {15785},
Pages = {184-199},
Note = {2025 International Conference on Cross Cultural Design-CCD-Annual,
   Goeteborg, SWEDEN, JUN 22-27, 2025},
Abstract = {With the rapid advancement of digital technologies, generative
   artificial intelligence (AIGC) and 3D modeling technology are
   increasingly influencing the domain of clothing design. As a form of art
   deeply imbued with cultural attributes, clothing design is witnessing a
   transition from monolithic styles to a trend characterized by
   multicultural integration, driven by an escalating demand for cultural
   diversity. Traditional methods of clothing design, which heavily rely on
   the designer's personal experience and cultural understanding, often
   fail to adequately address the profound impact of cultural background on
   user needs, aesthetic preferences, and behavioral patterns. This poses
   significant challenges in achieving a balance between design innovation
   and cultural dissemination within a multicultural context. However, AIGC
   technology offers novel opportunities for intelligent adaptation to
   cultural differences. In particular, within the contemporary societal
   context of cultural integration, the challenge of balancing cultural
   diversity with design efficiency has become pressing. Therefore, this
   study proposes and validates a ``Human-AI-3D Modeling{''} collaborative
   model aimed at exploring how to achieve equilibrium between cultural
   adaptation and design innovation in a globalized setting. The key
   findings of this research are as follows: (1) The incorporation of
   generative AI tools, such as Midjourney (MJ), effectively overcomes
   creative limitations faced by designers, expanding the boundaries of
   design thinking through intelligent inspiration generation. (2) The
   application of Style 3D's virtual garment modeling technology simulates
   clothing fit on the human body, enabling designers to rapidly adjust
   patterns and sizes, thereby streamlining traditional sample-making
   processes and markedly enhancing design efficiency. (3) Within the
   human-machine collaborative framework, where designers act as guides and
   AI and 3D modeling technologies serve as executors, the integration of
   multicultural symbols can be effectively promoted, thereby enriching
   both the cultural inclusivity and innovative potential of designs.
   Through practical applications in design competitions, the efficacy of
   the ``Human-AI-Style3D{''} collaborative model has been substantiated,
   fostering advancements in the clothing industry concerning both
   technological innovation and cultural dissemination. Furthermore, this
   study explores leveraging AI technology and 3D modeling for the rapid
   customization of personalized designs within a global cultural context,
   optimizing design across multiple dimensions and enhancing market
   competitiveness.},
