   Zhang, Yanting; Guo, Jingyi; Yan, Cairong; Fang, Zhijun, Donghua Univ, Sch Comp Sci \& Technol, Shanghai, Peoples R China.},
DOI = {10.1007/978-981-97-8620-6\_42},
ISSN = {0302-9743},
