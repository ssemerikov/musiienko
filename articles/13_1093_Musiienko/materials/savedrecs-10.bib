@inproceedings{ WOS:001533792800039,
Author = {Wang, Yujie},
Book-Group-Author = {IEEE},
Title = {Fashion Design Copyright Protection System Combining AI Color Trend
   Prediction Model and Blockchain Hash Storage Technology},
Booktitle = {2025 7TH INTERNATIONAL CONGRESS ON HUMAN-COMPUTER INTERACTION,
   OPTIMIZATION AND ROBOTIC APPLICATIONS, ICHORA},
Series = {International Congress on Human-Computer Interaction Optimization and
   Robotic Applications},
Year = {2025},
Note = {7th International Congress on Human-Computer Interaction, Optimization
   and Robotic Applications-ICHORA, Ankara, TURKIYE, MAY 23-24, 2025},
Organization = {Institute of Electrical and Electronics Engineers Inc; Ted University},
Abstract = {While affecting some significant changes in the industry, the
   advancement of fashion technology presents challenges such as rights to
   IP and anticipating frenzied consumer color preferences. This conference
   paper presents a promising approach with two components for further
   development including AI for colour trend prediction and blockchain for
   fashion design IP. By analyzing large amounts of data from sources like
   social networks, previous sales, and cultural references, AI allows
   designers to make sound decisions when it comes to the upcoming fashion
   seasons. Blockchain has notable benefits of maintaining a record of
   original designs and a complete deterring solution to plagiarism and
   counterfeits by creating a time-stamped and non-changeable block of data
   that cannot be hacked. Using a qualitative case study methodology, this
   paper examines the adoption of AI and blockchain technologies by two
   luxury fashion brands: Burberry and LVMH are two of the leading luxury
   brands with diverse product portfolios and covering different segments
   of the luxury goods market. These brands leverages AI for real time
   trends analysis and blockchain for intellectual property rights.
   Information was collected from relevant sources such as journals,
   organization's annual reports, and cases. In conclusion, this paper
   posits that integrating AI with blockchain promotes innovation where the
   IP of designers is protected. It is suggested that more brands adopt
   them, especially the small ones to avoid getting left behind by rivals.
   Possible limitations including cost and how they may affect creativity
   and possible implications for future research are also considered.},
