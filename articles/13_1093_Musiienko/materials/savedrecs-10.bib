@article{ WOS:001420398600001,
Author = {Qian, Yi and Xue, Wenliang and Wei, Mengyuan},
Title = {Interpretable machine learning in the analysis of macroscopic structural
   parameters influencing fabric color perception},
Journal = {JOURNAL OF THE TEXTILE INSTITUTE},
Year = {2025},
Volume = {116},
Number = {11},
Pages = {2814-2825},
Month = {NOV 2},
Abstract = {This study investigates the impact of fabric macroscopic structural
   parameters on color perception, specifically focusing on the lightness
   and chroma perception of red, yellow, green, and blue fabrics. Utilizing
   the XGBoost model and Shapley Additive Explanations (SHAP) for
   interpretability, we identify warp linear density as the core feature of
   color perception, exhibiting complex nonlinear effects that vary across
   different fabric colors. Our findings reveal that increasing warp linear
   density leads to significant changes in both lightness and chroma
   perception, highlighting a critical threshold effect where the
   contribution direction shifts. Additionally, we explore the roles of
   weft linear density, warp density, and weft density, which, although
   secondary, significantly influence color perception. The analysis also
   underscores the importance of fabric weave, as different weaving
   patterns exhibit distinct contributions to color perception,
   particularly in chroma perception. Overall, this research enhances the
   understanding of the intricate relationships between fabric
   macro-structure and optical properties, providing valuable insights for
   textile design and potential applications in AI-driven smart fabric
   design.},
