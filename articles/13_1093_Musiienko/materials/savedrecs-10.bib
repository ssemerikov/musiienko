Title = {Application and Optimization of Shanxi Fahua Art Elements Empowered by
   Artificial Intelligence in Clothing Design},
Booktitle = {DESIGN, USER EXPERIENCE, AND USABILITY, DUXU 2025, PT III},
Series = {Lecture Notes in Computer Science},
Year = {2025},
Volume = {15796},
Pages = {235-251},
Note = {14th International Conference on Design User Experience and
   Usability-DUXU-Annual, Goeteborg, SWEDEN, JUN 22-27, 2025},
Abstract = {With the development of Artificial Intelligence (AI) technology, the
   application of AI in Fashion design promotes the integration of
   traditional art elements with modern design. This paper discusses the
   innovative application of Shanxi Fahua ware colors and patterns in
   modern Fashion design, and optimizes the design with the assistance of
   AI to promote the inheritance of traditional culture. Shanxi Fahua ware
   is known for its exquisite colors and patterns, and it is a design
   challenge to combine these elements with modern design to preserve the
   traditional characteristics and meet modern aesthetics.
   This study combines qualitative analysis and design exploration to
   analyze the artistic characteristics of Shanxi Fahua ware and reorganize
   and optimize the patterns with the help of artificial intelligence
   technology. Ultimately, the results were optimized using the AI design
   platform and Photoshop to ensure that the work retained the essence of
   traditional art while meeting the needs of modern fashion design.
   This study shows that AI can effectively combine traditional elements
   with modern design, increasing creative freedom and design efficiency.
   Despite the challenges, AI provides a new perspective on the application
   of traditional culture in fashion design and promotes cultural heritage.},
