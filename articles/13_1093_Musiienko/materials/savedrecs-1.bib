Title = {A fuzzy evaluation method based on fuzzy consistency matrix for
   evaluating maintenance design program: Case study on heavy vehicle
   systems},
Booktitle = {SAFETY AND RELIABILITY - SAFE SOCIETIES IN A CHANGING WORLD},
