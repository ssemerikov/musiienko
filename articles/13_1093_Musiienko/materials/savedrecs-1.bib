@incollection{ WOS:000488759300004,
Author = {Mulholland, Neil},
Book-Author = {Mulholland, N},
Title = {Homo Artifex, Gnothi Sauton},
Booktitle = {RE-IMAGINING THE ART SCHOOL: PARAGOGY AND ARTISTIC LEARNING},
Series = {Creativity, Education and the Arts},
Year = {2019},
Pages = {19-37},
Abstract = {Two broad imaginaries are simultaneously manifest in art schools: a
   concept of art ('what' is to be learned) and a concept of studentship
   ('how' is it to be learned). The answers given to these mutually
   constitutive questions establish categorical and behavioural schema that
   generate different boundary formations, territorialising art students as
   subjects by scripting group composition and differentiation. Since there
   are no essential components of an artistic curriculum, there are no
   straightforward answers to these questions. Art schools oscillate
   between `major artistic' and `minor monotechnical' ideas of educational
   purpose, and, largely, celebrate this diversity and flexibility as a
   distinctive strength. Presently, instrumentalist pressure to articulate
   exactly `what is to be learned' encourages diglossic art schools to
   pursue identarian thinking, producing monocultural processes of
   identification and rationalisation that can be causal pathways to
   inequality in art and the wider world. Rehearsing how `hidden'
   monocultural imaginaries play out as a thought experiment might enable
   art schools to counter educational instrumentalism, and manage their
   material resources more equitably. With this in mind, this chapter
   reformulates educational questions of `what' and `how', so that they are
   directed in turn at `minor' and `major' voices broadly representative of
   the European art school's developmental diglossia. Different answers to
   these questions subjectivise art students by establishing distinctive,
   yet inequitable, boundary formations. Must art students choose between a
   minor or major ethics of identification, or, can they adopt a pragmatic
   educational diglossia that embraces heterogeneity and dissonance as
   assets?},
Publisher = {PALGRAVE},
Address = {HOUNDMILLS, BASINGSTOKE RG21 6XS, ENGLAND},
Type = {Article; Book Chapter},
Language = {English},
Affiliation = {Mulholland, N (Corresponding Author), Univ Edinburgh, Edinburgh Coll Art, Edinburgh, Midlothian, Scotland.
   Mulholland, Neil, Univ Edinburgh, Edinburgh Coll Art, Edinburgh, Midlothian, Scotland.},
DOI = {10.1007/978-3-030-20629-1\_2},
ISBN = {978-3-030-20629-1; 978-3-030-20628-4},
Keywords = {Artistic curriculum; Diversity; Flexibility},
