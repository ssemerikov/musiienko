@inproceedings{ WOS:000243629600056,
Author = {Kulkarni, Arun},
Editor = {Chu, HW and Savoie, MJ and Sanchez, B},
Title = {Knowledge discovery using fuzzy neural network models},
Booktitle = {3rd International Conference on Computing, Communications and Control
   Technologies, Vol 1, Proceedings},
Year = {2005},
Pages = {305-310},
Note = {3rd International Conference on Computing, Communications and Control
   Technologies, Austin, TX, JUL 24-27, 2005},
Organization = {Int Inst Informat \& Syst; Int Federat Syst Res},
Abstract = {In this paper, we describe a new method to extract and optimize
   classification rules using fuzzy neural networks. The fuzzy neural
   networks consist of two stages. The first stage represents a fuzzifier
   block and the second stage represents the inference engine. After
   training, classification rules are extracted by backtracking along the
   weighted paths through the fuzzy neural network. The extracted rules are
   then optimized by use of a Fuzzy Associate Memory (FAM) bank. As an
   illustration, we use the algorithm to extract classification rules from
   the Iris data set and a multispectral image obtained with a Landsat
   Thematic Mapper (TM) sensor. In order to verify the rule extraction
   method, measures such as the overall accuracy, producer's accuracy,
   user's accuracy, kappa coefficient, and fidelity are used.},
