@article{ WOS:000083304000008,
Author = {Ghosh, A and Tanaka, H},
Title = {On making neural network based learning systems robust},
Journal = {IETE JOURNAL OF RESEARCH},
Year = {1998},
Volume = {44},
Number = {4-5},
Pages = {219-225},
Month = {JUL-OCT},
Abstract = {A method for making neural network based learning systems robust with
   respect to component failure (damaging of nodes/links) is suggested in
   the present investigation. The method allows some of the components to
   fail at various instants of the entire learning process. The change in
   error value caused by this damage will be adjusted while the other
   components learn their parameters during the rest part of learning. The
   damaging/component failure process has been modeled as a Poisson
   process. The instants or moments of damaging are chosen by statistical
   sampling. The components to be damaged are determined randomly. As an
