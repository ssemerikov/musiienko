@article{ WOS:001630597700001,
Author = {Francis, Jain M. and Chandhini, G. and Chamakuri, Nagaiah},
Title = {An adaptive residual-structured and scheduled loss weighting framework
   for enhancing physics-informed neural networks in solving partial
   differential equations},
Journal = {COMMUNICATIONS IN NONLINEAR SCIENCE AND NUMERICAL SIMULATION},
Year = {2026},
Volume = {153},
Month = {FEB},
Abstract = {In this work, we introduce an adaptive Physics-Informed Residual Neural
   Network (aPIRNN) that enhances the performance of the physics-informed
   neural network (PINN) by combining an adaptive residual network (ResNet)
   architecture with an epoch-dependent scheduled loss weighting strategy
   to solve partial differential equations (PDEs). The proposed model
   mitigates the challenges faced by PINN due to architectural limitations,
   cost function formulation leading to training imbalance between various
   residual terms, and also due to the nature of the governing differential
   equations. The adaptive residual structure improves the flow of the
   gradient and the representation of the solution, while dynamic weighting
   of the loss function components helps improve the training imbalance in
   the loss function. In addition, we incorporate a second-order adaptive
   optimizer, Shampoo with Adam in the Preconditioner eigenbasis (SOAP) in
   aPIRNN, to further accelerate the optimization. Our comprehensive
   illustration using benchmark PDEs demonstrates that aPIRNN outperforms
   conventional PINN, Physics-Informed Kolmogorov-Arnold Network (PIKAN),
   and recent variants of PINN. In addition, we investigated the impact of
   mixed-precision training for PINNs.},
