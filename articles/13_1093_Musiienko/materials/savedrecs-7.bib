@article{ WOS:001114229700001,
Author = {Zou, Jinping and Yu, Jialin and Hu, Pengwei and Zhao, Long and Shi,
   Shaoping},
Title = {STAGAN: An approach for improve the stability of molecular graph
   generation based on generative adversarial networks},
Journal = {COMPUTERS IN BIOLOGY AND MEDICINE},
Year = {2023},
Volume = {167},
Month = {DEC},
Abstract = {With the wide application of deep learning in Drug Discovery, deep
   generative model has shown its advantages in drug molecular generation.
   Generative adversarial networks can be used to learn the internal
   structure of molecules, but the training process may be unstable, such
   as gradient disappearance and model collapse, which may lead to the
   generation of molecules that do not conform to chemical rules or a
   single style. In this paper, a novel method called STAGAN was proposed
   to solve the difficulty of model training, by adding a new gradient
   penalty term in the discriminator and designing a parallel layer of
   batch normalization used in generator. As an illustration of method,
   STAGAN generated higher valid and unique molecules than previous models
   in training datasets from QM9 and ZINC-250K. This indicates that the
   proposed method can effectively solve the instability problem in the
   model training process, and can provide more instructive guidance for
   the further study of molecular graph generation.},
