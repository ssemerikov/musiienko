@article{ WOS:001000471100001,
Author = {He, Shuai and Li, Jiali},
Title = {Practice and research on non-foreign heritage culture inheritance
   education in universities based on information fusion technology},
Journal = {APPLIED MATHEMATICS AND NONLINEAR SCIENCES},
Year = {2023},
Month = {2023 JUN 3},
Abstract = {It has gradually become a trend to infiltrate the knowledge of
   non-heritage culture and inherit the spirit of non-heritage culture and
   ethnic crafts in art education in colleges and universities. The purpose
   of this paper is to discuss the significance of ethnic crafts in
   non-heritage culture to art education in colleges and universities, the
   problems faced by the integration of ethnic crafts in non-heritage
   culture into art education in colleges and universities, and the
   transmission path of ethnic crafts in non-heritage culture in art
   education in colleges and universities. We hope to enhance deep
   connection between college art education and non-heritage culture by
   increasing research efforts, so that students will pay attention to the
   preservation of non-heritage culture and pass on the ethnic crafts of
   non-heritage culture in college studies. This paper develops research
   education and the cultivation of intangible cultural heritage through
   information fusion-based technology. The construction objectives of the
   multi-source information integration platform are proposed, and the
   overall architecture, functions, interfaces, and hardware architecture
   of the platform are designed. Analyze the connection between information
   fusion and information integration, and clarify the implementation
   process of multi-source information fusion technology. The two-level
   information fusion model of diagnosis constructed in this paper can
