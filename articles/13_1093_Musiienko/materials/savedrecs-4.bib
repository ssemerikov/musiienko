Author = {Kashaiuk, Viktoriia and Panasiuk, Svitlana and Stepaniuk, Ihor and
   Kukharyk, Hanna and Kosakovska, Lesia},
Title = {Digital transformation of musical and choreographic art: Preserving
   national archetypes},
Journal = {MUSICA HODIE},
Year = {2025},
Volume = {25},
Abstract = {The rapid development of digital technologies created the need for the
   development of methodological approaches to the integration into the
   performing arts while preserving cultural authenticity. The study aimed
   to develop a set of criteria for preserving national identity during the
   implementation of digital innovations in musical and choreographic art.
   The research adopted a systematic approach to the study of the
   transformation of cultural archetypes in the digital space. Specific
   manifestations of Ukrainian archetypes (Sophianity, the word, the land)
   and three levels of interaction with digital tools were identified:
   structural, regulative, and representative. An authenticity assessment
   table was created that systematised musical elements, choreographic
   elements, permissible transformations, and technological solutions
   across three categories: basic elements of national tradition, elements
   of partial processing, and generative forms. Technological solutions for
   preserving authenticity were proposed: motion capture systems for
   recording national plasticity, spectral analysis algorithms for
   preserving the timbral characteristics of folk instruments, and neural
   networks for analysing and reproducing folkloric elements. Using the
   example of the musical and choreographic work ``The Passions of
   Taras{''} by Yevhen Stankovych, the effectiveness of the developed
   approaches for preserving cultural codes during digital modernisation
   was demonstrated.},
