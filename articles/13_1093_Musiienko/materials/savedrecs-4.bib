@inproceedings{ WOS:001562317600005,
Author = {Hsuan, Lu I. and Wei, Zhao Zeng},
Book-Group-Author = {IEEE},
Title = {The Opportunities and Ethical Considerations of AIGenerated Art in Art
   Education},
Booktitle = {2025 6TH INTERNATIONAL CONFERENCE ON INFORMATION TECHNOLOGY AND
   EDUCATION TECHNOLOGY, ITET},
Year = {2025},
Pages = {22-29},
Note = {6th International Conference on Information Technology and Education
   Technology-ITET, Fukui-shi, JAPAN, MAY 09-11, 2025},
Organization = {Tottori University},
Abstract = {In an era of rapid technological advancement, artificial intelligence
   (AI) has become the driving force for innovation in various industries.
   In higher education in art and design, AI-generated art offers students
   new ways to create, explore, and learn. This study aims to design a
   university-level art education course that incorporates artificial
   intelligence art and examine its effects on students' learning
   motivation, drawing skills, creative expression, and awareness of
   artificial intelligence ethics. This study analyzes the current
   application status of artificial intelligence art creation in art
   education through literature review, and explores its impact on
   students' creative behavior and learning patterns. In addition, by
   synthesizing relevant research, this study explores the ethical issues
   raised by AI-created art, including copyright ownership, originality
   challenges, the impact of AI on traditional artistic skills, and
   students' views and attitudes toward AI-assisted creation. The results
   of the study show that the artwork created by artificial intelligence
   significantly improves students' creative thinking and painting skills,
   and is especially beneficial for students with weak artistic
   foundations. For students with artistic experience, AI serves primarily
   as a tool for inspiration and skill diversification. However,
   over-reliance on AI may reduce independent creative abilities and affect
   time management. This study suggests that art education should balance
   AI generation and traditional art methods, while strengthening AI ethics
   education to help students develop a correct understanding and critical
   thinking about AI technology.},
