@article{ WOS:001524292800001,
Author = {Ibanez, Ana Marques and Hernandez, Paula Delgado},
Title = {Generative models in AI as educational research: the impact of
   artificial intelligence on art education},
Journal = {REDU-REVISTA DE DOCENCIA UNIVERSITARIA},
Year = {2025},
Volume = {23},
Number = {1},
Pages = {7-25},
Month = {JAN-JUN},
Abstract = {Recent advances and the widespread availability of emerging artificial
   intelligence technologies provide new tools that facilitate expanded
   creativity and the creation of generative art in the fields of art and
   education. We analyse the applicability of AI in primary and
   postgraduate education through two practical classroom experiences based
   on the creation of images from text using AI-based models. We start by
   reviewing existing AI-generated image production practices in the fields
   of fine art and art education before designing the two educational
   experiences implemented in the project. We employ collaborative
   methodology that utilises AI as a tool to create images with a focus on
   the process rather than on the final product, combining handmade and
   digital processes and placing emphasis on human creativity. We present
   two practical experiences carried out with postgraduate and primary
   school students, employing a combination of artistic genres and styles
   forthe creation of children's images and illustrations. We also
   establish a table of premises and objectives as a means of guiding the
   effective use of AI in education. AI constitutes a powerful new set of
   tools that can support and enhance technical and creative skills during
   the process of creating a work of art, permitting quick and easy
   exploration of multiple alternatives. However, it should not be regarded
   as a definitive solution but rather a procedural technique for creating
   images by fostering artistic and expressive skills.},
