Editor = {Alfred, R and Lim, Y and Haviluddin, H and On, CK},
Title = {A Multi-Layer Perceptron Model in Analyzing Parametric Classification of
   Students' Assessment Results in K12},
Booktitle = {COMPUTATIONAL SCIENCE AND TECHNOLOGY (ICCST 2019)},
