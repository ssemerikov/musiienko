@article{ WOS:001481370900001,
Author = {Yang, Jie and Wang, Shuo},
Title = {THE BEHAVIOR ANALYSIS OF DEEP LEARNING MODEL IN THE TREATMENT OF
   DEPRESSION RESEARCH},
Journal = {JOURNAL OF MECHANICS IN MEDICINE AND BIOLOGY},
Year = {2025},
Volume = {25},
Number = {05},
Month = {JUN},
Abstract = {In recent years, students in arts programs have become particularly
   vulnerable to psychological challenges, driven by academic pressure,
   creative anxiety, and the unique emotional expression demands of their
   field. Among these challenges, symptoms of depression have been
   especially prominent. As a result, effective psychological interventions
   aimed at promoting emotional regulation and overall mental well-being
   have become increasingly urgent. This study evaluates the effectiveness
   of a comprehensive behavioral intervention method that integrates an
   emotion analysis model to alleviate depressive symptoms and improve
   mental health. The study is conducted over a three-month period at an
   art university, involving 200 art students. Participants are divided
   into an experimental group and a control group. The experimental group
   receives a behavioral intervention combining emotion analysis,
   psychological counseling, and art therapy, while the control group
   undergoes only standard psychological counseling. A Bidirectional Long
   Short-Term Memory (Bi-LSTM) emotion detection model is employed to
   monitor students' emotional changes in real time, providing targeted
   support for both psychological counseling and art therapy. The results
   indicated that the Bi-LSTM model outperforms other models across several
   key metrics, including accuracy (91.5\%), F1 score (89.2\%), Area Under
   the Curve (AUC, 0.9), and Cohen's Kappa (0.82), demonstrating its
   superior performance in emotion analysis tasks. Following the behavioral
   intervention, the experimental group exhibits a significant reduction in
   average depression scores, decreasing from 40.6 to 25.4, representing an
   improvement rate of 37.4\%. Emotional states also improve significantly:
   depressive emotions decrease from 65\% to 25\%, positive emotions
   double, and negative emotions are reduced by over 50\%. Participants
   express high overall satisfaction with the behavioral intervention, with
   art therapy receiving the highest satisfaction rating (90\%). The
   findings suggest that combining deep learning-based emotion detection
   models with psychological counseling and art therapy effectively reduces
   depressive symptoms, enhances emotional well-being, and promotes mental
   health among art students. The exceptional performance of the Bi-LSTM
   model in emotion classification provides a reliable foundation for
   real-time emotion monitoring and analysis. Furthermore, the unique
   contributions of art therapy enhance the efficacy of the behavioral
   intervention, offering a valuable approach to supporting the
   psychological health of students in creative disciplines.},
