Address = {ONE NEW YORK PLAZA, SUITE 4600, NEW YORK, NY, UNITED STATES},
Type = {Article},
Language = {English},
Affiliation = {Li, XK (Corresponding Author), Fuyang Normal Univ, Sch Business, Fuyang 236037, Peoples R China.
