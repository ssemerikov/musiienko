Note = {6th Interdisciplinary and Virtual Conference on Arts in Education
   (CIVAE), ELECTR NETWORK, FEB 28-29, 2024},
Abstract = {The integration of Artificial Intelligence (AI) in art education
   promises to transform art teaching and learning, offering opportunities
   to personalize the educational experience and foster global
   collaboration. However, this transformation poses challenges in terms of
