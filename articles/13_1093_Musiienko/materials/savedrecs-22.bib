Language = {English},
Affiliation = {Memarian, B (Corresponding Author), Simon Fraser Univ, Fac Educ, Vancouver, BC, Canada.
   Memarian, Bahar; Doleck, Tenzin, Simon Fraser Univ, Fac Educ, Vancouver, BC, Canada.},
DOI = {10.1007/s10639-024-12679-y},
EarlyAccessDate = {MAY 2024},
ISSN = {1360-2357},
EISSN = {1573-7608},
Keywords = {Higher education; Artificial intelligence (AI); Pedagogy; Teaching;
   Learning},
