@article{ WOS:001631918000010,
Author = {Bidry, Mahmoud and Hanine, Mohamed and Ouaguid, Abdellah and Obidallah,
   Waeal J.},
Title = {Transforming Education With Generative AI: A Comprehensive Review of
   Advancements, Challenges, and Future Opportunities},
Journal = {IEEE ACCESS},
Year = {2025},
Volume = {13},
Pages = {202938-202955},
Abstract = {The swift progress of technology and the rise of generative artificial
   intelligence (generative AI) have significantly transformed educational
   paradigms, necessitating a thorough examination of their impacts and
   applications in learning environments. This systematic literature review
   aims to explore the evolving landscape of generative AI in education by
   analyzing a comprehensive selection of 55 studies indexed in Web of
   Science (WoS), selected for its high-quality peer-reviewed content and
   multidisciplinary coverage, that investigate the effectiveness of
   generative AI tools in enhancing educational outcomes. This review
   highlights their role in personalized learning experiences, adaptive
   assessments, and automated feedback systems. Our analysis highlights the
   potential of generative AI to foster engagement through interactive and
   immersive learning environments while also addressing the challenges of
   traditional educational models that often neglect individual learning
   styles and needs. Key themes emerged regarding the incorporation of AI
   technologies, including natural language processing and chatbot
   applications, which have proven beneficial in improving academic skills
   and optimizing administrative processes. This review also identifies
   pressing challenges requiring further exploration, including the ethical
   concerns surrounding data privacy and biases in algorithmic decision
   processes. These findings offer meaningful insights for educators and
   researchers, guiding future work toward leveraging generative AI to
   create more inclusive and impactful learning experiences.},
Publisher = {IEEE-INST ELECTRICAL ELECTRONICS ENGINEERS INC},
Address = {445 HOES LANE, PISCATAWAY, NJ 08855-4141 USA},
