Title = {Researching Character Design with Generative AI - Focusing on Creating
   Five Probiotic Characters},
Booktitle = {HCI INTERNATIONAL 2024-LATE BREAKING POSTERS, HCII 2024, PT II},
Series = {Communications in Computer and Information Science},
Year = {2025},
Volume = {2320},
Pages = {249-256},
Note = {26th International Conference on Human-Computer Interaction, HCII,
   Washington, DC, JUN 29-JUL 04, 2024},
Abstract = {This study explores integrating Generative AI tools, namely Adobe
   Firefly and ChatGPT, into character design. Character design is crucial
   across various creative sectors like animation, gaming, marketing, and
   education. Traditional methods demand time and expertise, but Generative
   AI has revolutionized with its creativity-enhancing and efficient tools.
   The research involves creating five probiotic characters to examine how
   Generative AI augments traditional design. We used ChatGPT for initial
   research and keyword extraction, and Adobe Firefly for visual creation
   and refinement, aiming to streamline while maintaining quality. Findings
   show Generative AI significantly improves speed and precision, allowing
   rapid iteration and diverse creativity. ChatGPT aids in information
   synthesis, while Adobe Firefly creates consistent visuals. Despite
   benefits, challenges like precise guidelines and human oversight are
   crucial for AI-generated content's accuracy and cohesion. Maintaining
   artistic vision across characters requires a structured approach.
   Generative AI offers substantial benefits, transforming workflows, and
   expanding creative horizons, emphasizing responsible AI use and
   suggesting areas for future research.},
