@article{ WOS:001204737900004,
Author = {Vaishya, Raju and Iyengar, Karthikeyan P. and Patralekh, Mohit Kumar and
   Botchu, Rajesh and Shirodkar, Kapil and Jain, Vijay Kumar and Vaish,
   Abhishek and Scarlat, Marius M.},
Title = {Effectiveness of AI-powered Chatbots in responding to orthopaedic
   postgraduate exam questions-an observational study},
Journal = {INTERNATIONAL ORTHOPAEDICS},
Year = {2024},
Volume = {48},
Number = {8},
Pages = {1963-1969},
Month = {AUG},
Abstract = {Purpose This study analyses the performance and proficiency of the three
   Artificial Intelligence (AI) generative chatbots (ChatGPT-3.5,
   ChatGPT-4.0, Bard Google AI (R)) and in answering the Multiple Choice
   Questions (MCQs) of postgraduate (PG) level orthopaedic qualifying
   examinations. Methods A series of 120 mock Single Best Answer' (SBA)
   MCQs with four possible options named A, B, C and D as answers on
   various musculoskeletal (MSK) conditions covering Trauma and Orthopaedic
   curricula were compiled. A standardised text prompt was used to generate
   and feed ChatGPT (both 3.5 and 4.0 versions) and Google Bard programs,
   which were then statistically analysed. Results Significant differences
   were found between responses from Chat GPT 3.5 with Chat GPT 4.0 (Chi
   square = 27.2, P < 0.001) and on comparing both Chat GPT 3.5 (Chi square
   = 63.852, P < 0.001) with Chat GPT 4.0 (Chi square = 44.246, P < 0.001)
   with. Bard Google AI (R) had 100\% efficiency and was significantly more
   efficient than both Chat GPT 3.5 with Chat GPT 4.0 (p < 0.0001).
   Conclusion The results demonstrate the variable potential of the
   different AI generative chatbots (Chat GPT 3.5, Chat GPT 4.0 and Bard
   Google) in their ability to answer the MCQ of PG-level orthopaedic
   qualifying examinations. Bard Google AI (R) has shown superior
   performance than both ChatGPT versions, underlining the potential of
   such large language processing models in processing and applying
   orthopaedic subspecialty knowledge at a PG level.},
