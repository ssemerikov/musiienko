@article{ WOS:001222833100001,
Author = {Herron, Ethan and Rade, Jaydeep and Jignasu, Anushrut and
   Ganapathysubramanian, Baskar and Balu, Aditya and Sarkar, Soumik and
   Krishnamurthy, Adarsh},
Title = {Latent Diffusion Models for Structural Component Design},
Journal = {COMPUTER-AIDED DESIGN},
Year = {2024},
Volume = {171},
Month = {JUN},
Abstract = {Recent advances in generative modeling, namely Diffusion models, have
   revolutionized generative modeling, enabling high-quality image
   generation tailored to user needs. This paper proposes a framework for
   the generative design of structural components. Specifically, we employ
   a Latent Diffusion model to generate potential designs of a component
   that can satisfy a set of problem-specific loading conditions. One of
   the distinct advantages our approach offers over other generative
   approaches is the editing of existing designs. We train our model using
   a dataset of geometries obtained from structural topology optimization
   utilizing the SIMP algorithm. Consequently, our framework generates
   inherently near-optimal designs. Our work presents quantitative results
   that support the structural performance of the generated designs and the
   variability in potential candidate designs. Furthermore, we provide
   evidence of the scalability of our framework by operating over voxel
   domains with resolutions varying from 32 3 to 128 3 . Our framework can
   be used as a starting point for generating novel near-optimal designs
   similar to topology-optimized designs.},
Publisher = {ELSEVIER SCI LTD},
