@inproceedings{ WOS:001476971200109,
Author = {Deldjoo, Yashar and He, Zhankui and McAuley, Julian and Korikov, Anton
   and Sanner, Scott and Ramisa, Arnau and Vidal, Rene and Sathiamoorthy,
   Maheswaran and Kasirzadeh, Atoosa and Milano, Silvia},
