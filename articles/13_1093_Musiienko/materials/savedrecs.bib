@article{ WOS:001543607200001,
Author = {Zhang, Emma Yann and Cheok, Adrian David and Pan, Zhigeng and Cai, Jun
   and Yan, Ying},
Title = {From Turing to Transformers: A Comprehensive Review and Tutorial on the
   Evolution and Applications of Generative Transformer Models},
Journal = {SCI},
Year = {2023},
Volume = {5},
Number = {4},
Month = {DEC 15},
Abstract = {In recent years, generative transformers have become increasingly
   prevalent in the field of artificial intelligence, especially within the
   scope of natural language processing. This paper provides a
   comprehensive overview of these models, beginning with the foundational
   theories introduced by Alan Turing and extending to contemporary
   generative transformer architectures. The manuscript serves as a review,
   historical account, and tutorial, aiming to offer a thorough
   understanding of the models' importance, underlying principles, and
   wide-ranging applications. The tutorial section includes a practical
   guide for constructing a basic generative transformer model.
   Additionally, the paper addresses the challenges, ethical implications,
   and future directions in the study of generative models.},
