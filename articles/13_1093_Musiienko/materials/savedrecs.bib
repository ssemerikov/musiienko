Title = {Tiered sampling step sharing strategy for accelerating diffusion-based
   image restoration of multi-phasic CT},
Booktitle = {MEDICAL IMAGING 2025: IMAGE PROCESSING},
Series = {Progress in Biomedical Optics and Imaging},
Year = {2025},
Volume = {13406},
Note = {2025 Conference on Medical Imaging, San Diego, CA, FEB 16-21, 2025},
Organization = {United Imaging Healthcare Co; Merck \& Co Inc; Philips Research},
Abstract = {Diffusion-based generative models are a novel class of generative models
   recently shown to outperform supervised learning-based methods and other
   generative models in various applications. Several pioneer studies have
   demonstrated the potential of applying diffusion models to the
   restoration of medical images. A major practical limitation of diffusion
   models is time consumption. In this study, we propose a novel
   acceleration technique targeting denoising diffusion probabilistic
   models (DDPM) processing of volumetric scans of multi-phasic CT. The
   proposed method utilizes a tiered sampling step sharing mechanism to
   utilize the anatomical similarity at multiple scales across different
   phases and different spatial slices. The proposed method enables 40x
   speed up compared to the conventional workflow while maintaining high
   fidelity restoration of the images.},
