@inproceedings{ WOS:001598852800091,
Author = {Emara, Mohamed and Farouk, Mohamed and Fakhr, Mohamed Waleed},
Book-Group-Author = {IEEE},
Title = {A comparative study between GAN and diffusion models for child image
   generation from parents'},
Booktitle = {2025 15TH INTERNATIONAL CONFERENCE ON ELECTRICAL ENGINEERING, ICEENG},
Year = {2025},
Note = {15th IEEE International Conference on Electrical
   Engineering-ICEENG-Annual, Cairo, EGYPT, MAY 12-15, 2025},
Organization = {Institute of Electrical and Electronics Engineers Inc},
Abstract = {Kinship image-based applications have evolved in the past decade. They
   are mainly used to identify and recognize relatives through the analysis
   of their features; with the recent breakthrough in generative models,
   Kinship Generation has emerged, focusing on generating images of
   relatives based on the images of other family members. This study
   introduces a child generation model that utilizes a diffusion model in
   combination with a vision transformer decoder to generate a child's
   image using their parents' images. The research evaluates the
   capabilities of both GAN-based and diffusion models, with results
   indicating that the diffusion models enhance the diversity and realism
   of generated children's images compared to traditional GAN-based
   methods.},
