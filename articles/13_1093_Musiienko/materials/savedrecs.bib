@inproceedings{ WOS:001331850102062,
Author = {Wang, Helin and Villalba, Jesus and Moro-Velazquez, Laureano and Hai,
   Jiarui and Thebaucour, Thomas and Dehak, Najim},
Book-Group-Author = {Int Speech Commun Assoc},
Title = {Noise-robust Speech Separation with Fast Generative Correction},
Booktitle = {INTERSPEECH 2024},
Series = {Interspeech},
Year = {2024},
Pages = {2165-2169},
Note = {25th Interspeech Conference, Kos, GREECE, SEP 01-05, 2024},
Organization = {Meta; Apple; Amazon Sci; AppTek; Google; Reg S Aegean; NexData;
   DataForce; Otter; Acad Coll Engn tel Aviv; Bar Ilan Univ},
Abstract = {Speech separation, the task of isolating multiple speech sources from a
   mixed audio signal, remains challenging in noisy environments. In this
   paper, we propose a generative correction method to enhance the output
   of a discriminative separator. By leveraging a generative corrector
   based on a diffusion model, we refine the separation process for
   single-channel mixture speech by removing noises and perceptually
   unnatural distortions. Furthermore, we optimize the generative model
   using a predictive loss to streamline the diffusion model's reverse
   process into a single step and rectify any associated errors by the
   reverse process. Our method achieves state-of-the-art performance on the
   in-domain Libri2Mix noisy dataset, and out-of-domain WSJ with a variety
   of noises, improving SI-SNR by 22-35\% relative to SepFormer,
   demonstrating robustness and strong generalization capabilities.},
