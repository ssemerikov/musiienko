Title = {Story-to-Images Translation: Leveraging Diffusion Models and Large
   Language Models for Sequence Image Generation},
Booktitle = {PROCEEDINGS OF THE 2ND WORKSHOP ON USER-CENTRIC NARRATIVE SUMMARIZATION
   OF LONG VIDEOS, NARSUM 2023},
