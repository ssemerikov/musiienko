Note = {2nd Workshop on User-Centric Narrative Summarization of Long Videos
   (NarSUM), Ottawa, CANADA, OCT 29, 2023},
Organization = {Assoc Comp Machinery; ACM SIGMM},
Abstract = {Diffusion models are catalyzing breakthroughs in creative fields, with a
   notable impact on text-to-image generation. This study centers on the
   transformation of textual narratives into coherent sequences of images-a
   process currently hampered by issues of consistency and contextual
   fidelity. To address these challenges, we propose a method utilizing a
