Year = {2024},
Volume = {36},
Number = {7},
Pages = {2814-2830},
Month = {JUL},
Abstract = {Deep generative models have unlocked another profound realm of human
   creativity. By capturing and generalizing patterns within data, we have
   entered the epoch of all-encompassing Artificial Intelligence for
   General Creativity (AIGC). Notably, diffusion models, recognized as one
   of the paramount generative models, materialize human ideation into
   tangible instances across diverse domains, encompassing imagery, text,
   speech, biology, and healthcare. To provide advanced and comprehensive
   insights into diffusion, this survey comprehensively elucidates its
   developmental trajectory and future directions from three distinct
   angles: the fundamental formulation of diffusion, algorithmic
   enhancements, and the manifold applications of diffusion. Each layer is
   meticulously explored to offer a profound comprehension of its
   evolution. Structured and summarized approaches are presented here.},
