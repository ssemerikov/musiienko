Note = {2024 International Conference on Quantum Computing and Engineering,
   Montreal, CANADA, SEP 15-20, 2024},
Organization = {Microsoft; Keysight Technologies Inc; Quantinuum Ltd; Qunasys Inc;
   Psiquantum Corp},
Abstract = {Generative models have gained attention for their proven effectiveness
   in various domains, from generating images to producing text. Diffusion
   models (DMs) have demonstrated superior performance compared to
   alternative techniques like generative adversarial networks (GANs) or
   autoencoders (AE). The research about DMs has advanced further with the
   proposition of latent diffusion models (LDMs), which employ DMs within
   the latent space to mitigate computational complexity while preserving
   high quality and flexibility. Quantum computing with its intrinsic
   characteristics of entanglement and superposition which enable high
   representational power, arises with the possibility of offering
   computational advantages over classical generative models. Inspired by
   current trends of classical generative models, we propose quantum latent
   diffusion models (QLDMs) to enable computationally efficient DMs with
   the guidance of conditions on classical data. QLDMs offer solutions to
   the challenges faced by classical generative models due to their large
   number of parameters, while still achieving comparable results on
   datasets.},
