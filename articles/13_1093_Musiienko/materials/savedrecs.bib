@article{ WOS:001179444600005,
Author = {Kim, Kiduk and Cho, Kyungjin and Jang, Ryoungwoo and Kyung, Sunggu and
   Lee, Soyoung and Ham, Sungwon and Choi, Edward and Hong, Gil-Sun and
   Kim, Namkug},
Title = {Updated Primer on Generative Artificial Intelligence and Large Language
   Models in Medical Imaging for Medical Professionals},
Journal = {KOREAN JOURNAL OF RADIOLOGY},
