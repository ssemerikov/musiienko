@inproceedings{ WOS:001564473300075,
Author = {Rafner, Janet and Hjorth, Arthur and Risi, Sebastian and Philipsen,
   Lotte and Dumas, Charles and Biskjaer, Michael Mose and Noy, Lior and
   Tylen, Kristian and Bergenholtz, Carsten and Lynch, Jesse and Zana,
   Blanka and Sherson, Jacob},
