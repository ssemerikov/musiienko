Title = {Visual Design Process in the Era of Artificial Intelligence: Research on
   the Design Framework of Human-AI Collaboration in Branding Design},
Booktitle = {DESIGN, USER EXPERIENCE, AND USABILITY, DUXU 2025, PT VI},
