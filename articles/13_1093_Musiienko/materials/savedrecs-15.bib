@inproceedings{ WOS:001295128100045,
Author = {Purkayastha, Saptarshi and Isaac, Rohan and Anthony, Sharon and Shukla,
   Shikhar and Krupinski, Elizabeth A. and Danish, Joshua A. and Gichoya,
   Judy Wawira},
Editor = {Juarez, JM and Marcos, M and Stiglic, G and Tucker, A},
Title = {A General-Purpose AI Assistant Embedded in an Open-Source Radiology
   Information System},
Booktitle = {ARTIFICIAL INTELLIGENCE IN MEDICINE, AIME 2023},
Series = {Lecture Notes in Artificial Intelligence},
Year = {2023},
Volume = {13897},
Pages = {373-377},
Note = {21st International Conference on Artificial Intelligence in Medicine
   (AIME), Portoroz, SLOVENIA, JUN 12-15, 2023},
Abstract = {Radiology AI models have made significant progress in near-human
   performance or surpassing it. However, AI model's partnership with human
   radiologist remains an unexplored challenge due to the lack of health
   information standards, contextual and workflow differences, and data
   labeling variations. To overcome these challenges, we integrated an AI
   model service that uses DICOM standard SR annotations into the OHIF
   viewer in the open-source LibreHealth Radiology Information Systems
   (RIS). In this paper, we describe the novel Human-AI partnership
   capabilities of the platform, including few-shot learning and swarm
   learning approaches to retrain the AI models continuously. Building on
   the concept of machine teaching, we developed an active learning
   strategy within the RIS, so that the human radiologist can
   enable/disable AI annotations as well as ``fix{''}/relabel the AI
   annotations. These annotations are then used to retrain the models. This
   helps establish a partnership between the radiologist user and a
   user-specific AI model. The weights of these user-specific models are
   then finally shared between multiple models in a swarm learning
   approach.},
