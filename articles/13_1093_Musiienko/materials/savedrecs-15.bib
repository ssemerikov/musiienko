@inproceedings{ WOS:001543736500095,
Author = {Thorn, Seth D.},
Book-Group-Author = {ACM},
Title = {Diffractive Constellations: Activating Human-Machine Co-Creation in
   Violin Performance through Embedded Modular Coding},
Booktitle = {PROCEEDINGS OF THE 2025 CONFERENCE ON CREATIVITY AND COGNITION, C\&C
   2025},
Year = {2025},
Pages = {854-858},
Note = {17th Conference on Creativity and Cognition-C\&C, ELECTR NETWORK, JUN
   23-25, 2025},
Organization = {Association for Computing Machinery; ACM SIGCHI},
Abstract = {Diffractive Constellations is a live performance and research project
   that combines acoustic violin improvisation with custom modular audio
   hardware. It extends the patching ethos of environments like Max into
   physical DSP modules, allowing sound and gesture to be shaped through
   embedded, materially constrained interactions. Each unit is prototyped
   in a visual patching interface, compiled onto embedded hardware, and
   interconnected in a Eurorack framework. Drawing on Karen Barad's
   diffractive methodology, which foregrounds relational emergence over
   fixed boundaries, the system invites performer, code, and matter to
   co-constitute musical meaning. The modules capture, transform,
   re-sequence, and re-imagine violin gesture and sound by processing
   control voltages and audio signals that eschew prescriptive layers
   (e.g., MIDI) and standard design tropes. Minimal signals convey
   intentionality, echoing participatory sensemaking questions about the
   threshold of agency and foregrounding an ecological, materialist view of
   human-machine co-creation.},
