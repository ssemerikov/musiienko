Title = {What Makes It Mine? Exploring Psychological Ownership over Human-AI
   Co-Creations},
Booktitle = {PROCEEDINGS OF THE 50TH GRAPHICS INTERFACE CONFERENCE, GI 2024},
Year = {2024},
Note = {50th Graphics Interface conference (GI), Dalhousie Univ, Halifax,
   CANADA, JUN 03-06, 2024},
Abstract = {As generative AI (GenAI) rapidly evolves, human-AI collaboration emerges
   as a prevalent new working style. However, within this collaborative
   pipeline, multiple stakeholders are involved besides the user and the
   system itself, raising controversy around ownership over co-creations.
   In this paper, we explored everyday users' sense of ownership toward
   human-AI co-creation, aiming to provide insights for practitioners on
   future GenAI design to enhance user experience. We identify three
   primary factors associated with people's perception of psychological
   ownership towards human-AI co-creation and systematically analyze
   individuals' approaches to assessing these factors. The findings serve
   to inform strategies for facilitating an appropriate sense of ownership
   for productive and safe usage of GenAI tools.},
