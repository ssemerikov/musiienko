@article{ WOS:000788104400001,
Author = {Magalhaes, Juliana G. de S. and Polinko, Adam P. and Amoroso, Mariano M.
   and Kohli, Gursimran S. and Larson, Bruce C.},
Title = {The Predicting Tree Growth App: an algorithmic approach to modelling
   individual tree growth},
Journal = {ECOLOGICAL MODELLING},
Year = {2022},
Volume = {467},
Month = {MAY},
Abstract = {PredictingTreeGrowth is free and open-source application software
   written in Python 3.7 that allows easy and fast development of
   predictive models using the Recurrent Neural Network (RNN)/Long
   Short-Term Memory (LSTM) framework. RNNs have an upgraded architecture
