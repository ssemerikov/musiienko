Title = {IntellectSeeker: A Personalized Literature Management System with the
   Probabilistic Model and Large Language Model},
Booktitle = {KNOWLEDGE SCIENCE, ENGINEERING AND MANAGEMENT, PT V, KSEM 2024},
Series = {Lecture Notes in Artificial Intelligence},
