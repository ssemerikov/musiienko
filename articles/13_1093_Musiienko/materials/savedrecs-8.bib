@article{ WOS:001566267100001,
Author = {Tilton, Annemarie K. and Caplan, Brian E. and Cole, Brian J.},
Title = {Generative AI in consumer health: leveraging large language models for
   health literacy and clinical safety with a digital health framework},
Journal = {FRONTIERS IN DIGITAL HEALTH},
Year = {2025},
Volume = {7},
Month = {AUG 26},
Abstract = {Generative AI, powered by large language models, is transforming
   consumer health by enhancing health literacy and delivering personalized
   health education. However, ensuring clinical safety and effectiveness
   requires a robust digital health framework to address risks like
   misinformation and inequitable communication. This mini review examines
   current use cases for generative AI in consumer health education,
   highlights persistent challenges, and proposes a clinician-informed
   framework to evaluate safety, usability, and effectiveness. The RECAP
   model-Relevance, Evidence-based, Clarity, Adaptability, and
   Precision-offers a pragmatic lens to guide responsible implementation of
   AI in patient-facing tools. By connecting insights from past digital
   health innovations to the opportunities and pitfalls of large language
   models, this paper provides both context and direction for future
   development.},
Publisher = {FRONTIERS MEDIA SA},
