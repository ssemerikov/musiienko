Title = {Reassessing Java Code Readability Models with a Human-Centered Approach},
Booktitle = {PROCEEDINGS 2024 32ND IEEE/ACM INTERNATIONAL CONFERENCE ON PROGRAM
   COMPREHENSION, ICPC 2024},
Series = {International Conference on Program Comprehension},
