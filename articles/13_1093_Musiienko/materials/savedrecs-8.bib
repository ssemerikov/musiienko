@inproceedings{ WOS:001481475900057,
Author = {Ruf, Boris and Detyniecki, Marcin},
Book-Group-Author = {IEEE COMPUTER SOC},
Title = {The ⟪Huh?⟫ Button: Improving Understanding in Educational Videos with
   Large Language Models},
Booktitle = {2024 INTERNATIONAL SYMPOSIUM ON MULTIMEDIA, ISM},
Year = {2024},
Pages = {285-289},
Note = {26th International Symposium on Multimedia-ISM-Annual, Tokyo, JAPAN, DEC
   11-13, 2024},
Organization = {IEEE Computer Society},
Abstract = {We propose a simple way to use large language models (LLMs) in
   education. Specifically, our method aims to improve individual
   comprehension by adding a novel feature to online videos. We combine the
   low threshold for interactivity in digital experiences with the benefits
   of rephrased and elaborated explanations typical of face-to-face
   interactions, thereby supporting to close knowledge gaps at scale. To
   demonstrate the technical feasibility of our approach, we conducted a
   proof-of-concept experiment and implemented a prototype which is
   available for testing online. Through the use case, we also show how
   caching can be applied in LLM-powered applications to reduce their
   carbon footprint.},
