@inproceedings{ WOS:000380532905058,
Author = {Krause, Josua and Perer, Adam and Ng, Kenney},
Book-Group-Author = {ACM},
Title = {Interacting with Predictions: Visual Inspection of Black-box Machine
   Learning Models},
Booktitle = {34TH ANNUAL CHI CONFERENCE ON HUMAN FACTORS IN COMPUTING SYSTEMS, CHI
   2016},
Year = {2016},
Pages = {5686-5697},
Note = {34th Annual CHI Conference on Human Factors in Computing Systems
   (CHI4GOOD), San Jose, CA, MAY 07-12, 2016},
Organization = {Assoc Comp Machinery; SIG CHI},
Abstract = {Understanding predictive models, in terms of interpreting and
   identifying actionable insights, is a challenging task. Often the
   importance of a feature in a model is only a rough estimate condensed
   into one number. However, our research goes beyond these naive estimates
   through the design and implementation of an interactive visual analytics
   system, Prospector. By providing interactive partial dependence
   diagnostics, data scientists can understand how features affect the
   prediction overall. In addition, our support for localized inspection
   allows data scientists to understand how and why specific datapoints are
   predicted as they are, as well as support for tweaking feature values
   and seeing how the prediction responds. Our system is then evaluated
   using a case study involving a team of data scientists improving
   predictive models for detecting the onset of diabetes from electronic
   medical records.},
