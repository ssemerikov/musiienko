@article{ WOS:001578833600001,
Author = {Acican, Oyku and Luyten, Laurens},
Title = {Structurally integrated architectural design education: a computational
   design approach},
Journal = {ARCHITECTURAL ENGINEERING AND DESIGN MANAGEMENT},
Year = {2025},
Month = {2025 SEP 2},
Abstract = {This research explores teaching new strategies to enhance early
   structural integration skills of architects through computational design
   and structural analysis, that enable structural simulations,
   form-finding, and iterative design experiments. The research adopts a
   participatory action research methodology, in an educational context
   with architecture students. Structural integration steps were
   investigated within Jane Dark's design theory
   `generator-conjecture-analysis'. The structural integration strategies
   emphasized the cognitive shift toward viewing architectural forms as
   systems of structural elements, joints, and supports. Participants
   engaged in customized exercises developed to explore structural design
   variations within each student's project context with the goal of early
   structural integration, by using computational design and structural
   analysis. Students received feedback from experts, facilitating a
   continuous mapping between design ideas and structural consequences.
   This approach improved students' confidence, motivation, and creativity
   in structural integration. Key findings indicate that the tested
   teaching method can support developing some of the skills for
   structurally integrated design promoting structural reflection-in-action
   and flexibility in form-finding.},
