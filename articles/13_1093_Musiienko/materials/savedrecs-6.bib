@article{ WOS:001625865800001,
Author = {Alamasi, Rawan and Asfour, Omar S. and Ashmeel, Riyad},
Title = {The impact of generative AI on architectural design education: insights
   from hands-on experience with architecture students},
Journal = {AIN SHAMS ENGINEERING JOURNAL},
Year = {2026},
Volume = {17},
Number = {1},
Month = {JAN},
Abstract = {The integration of Generative Artificial Intelligence (GenAI) into
   architectural education has been increasingly explored for its potential
   influence on the design process. However, empirical evidence on its
   applications remains limited. This study aims to evaluate the impact of
   GenAI on students' performance in a supervised project conducted at King
   Fahd University of Petroleum and Minerals (KFUPM), Saudi Arabia. The
   study assessed the outcomes focusing on creativity, time efficiency, and
   design quality. The findings indicated that the test group demonstrated
   generally better performance than the control group, especially in
   design form and aesthetics, where an improvement of 14\% was observed.
   The study also interviewed experts in the field and discussed their
   similar experiences and recommendations in this regard. The study
   proposed a framework outlining the recommended levels of GenAI
   integration across the different design stages to help students and
   educators utilize GenAI tools while ensuring sufficient critical
   engagement.},
