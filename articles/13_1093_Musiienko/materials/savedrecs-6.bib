@article{ WOS:001547666900001,
Author = {Cudzik, Jan and Nessel, Michal},
Title = {Algorithmic space optimization in building adaptations: Generative
   design comparison},
Journal = {JOURNAL OF BUILDING ENGINEERING},
Year = {2025},
Volume = {112},
Month = {OCT 15},
Abstract = {Building adaptation for new functions presents significant challenges in
   architectural design, particularly when integrating digital automation
   technologies. Despite advances in AI and machine learning, a systematic
   comparison of fundamental algorithmic approaches for automated space
   allocation in building retrofitting remains unexplored, which limits the
   practical implementation of these approaches in feasibility studies.
   This research aims to develop and systematically compare three
   generative design approaches for automating hotel room allocation within
   existing building footprints: global rules (tessellation),
   self-organization, and mixed methods (corridor attraction). Three
   algorithms were developed using Rhinoceros 7 and Grasshopper, tested on
   50 diverse floor boundaries representing I, L, C, T, and H building
   typologies. Quantitative analysis measured room generation efficiency,
   while qualitative assessment involved 86 architecture students
   evaluating design outcomes using 10-point scales. A comparative analysis
   examined unit counts, space optimization metrics, and qualitative
   evaluations across all approaches. The global rules approach generated
   the highest number of valid rooms (1547 units), achieving superior space
   optimization and predictable results. Self-organization produced 1298
   units with irregular outcomes. A mixed approach yielded 1355 units,
   striking a balance between systematic control and design flexibility.
   This framework enables rapid exploration of building adaptation
   scenarios, supporting data-driven decision-making in early design
   phases. The research establishes a foundation for AI-enhanced
   architectural design systems. It contributes to optimized space reuse,
   with applications extending to parking lots, commercial buildings, and
   urban-scale design challenges.},
