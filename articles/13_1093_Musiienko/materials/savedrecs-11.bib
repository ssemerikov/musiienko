@inproceedings{ WOS:001593214400115,
Author = {Qiu, Ketai},
Editor = {Li, J},
Title = {Ever-Improving Test Suite by Leveraging Large Language Models},
Booktitle = {COMPANION PROCEEDINGS OF THE 33RD ACM INTERNATIONAL CONFERENCE ON THE
   FOUNDATIONS OF SOFTWARE ENGINEERING, FSE COMPANION 2025},
Year = {2025},
Pages = {1010-1012},
Note = {33rd International Symposium on Foundations of Software Engineering-FSE,
   Trondheim, NORWAY, JUN 23-27, 2025},
Organization = {Association for Computing Machinery},
Abstract = {Augmenting test suites with test cases that reflect the actual usage of
   the software system is extremely important to sustain the quality of
   long lasting software systems. In this paper, we propose E-Test, an
   approach that incrementally augments a test suite with test cases that
   exercise behaviors that emerge in production and that are not been
   tested yet. E-Test leverages Large Language Models to identify
   already-tested, not-yet-tested, and error-prone unit execution
   scenarios, and augment the test suite accordingly. Our experimental
   evaluation shows that E-Test outperforms the main state-of-the-art
   approaches to identify inadequately tested behaviors and optimize test
   suites.},
Publisher = {ASSOC COMPUTING MACHINERY},
Address = {1601 Broadway, 10th Floor, NEW YORK, NY, UNITED STATES},
Type = {Proceedings Paper},
Language = {English},
