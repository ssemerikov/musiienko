@article{ WOS:001638859900001,
Author = {Su, Chang and Wang, Xingyue and Chen, Yijiang},
Title = {Can multimodal large language models understand visual metaphors? An
   evaluation of MLLM's multi-perspective understanding capabilities for
   visual metaphors},
Journal = {EXPERT SYSTEMS WITH APPLICATIONS},
Year = {2026},
Volume = {303},
Month = {MAR 25},
Abstract = {Large language models excel in daily conversations, article writing and
   creative content generation but struggle with complex tasks like
   understanding visual metaphors. Such understanding requires complex
   logical and commonsense reasoning, as well as cross-domain knowledge
   integration. Existing research lacks datasets and comprehensive
   evaluation methods for assessing models' visual metaphor comprehension,
   ignoring the diversity of metaphor understanding. To address this, we
   constructed MetaVis4D, a fine-grained metaphor dataset, and designed
   four evaluation tasks: metaphorical characteristic understanding (Target
   domain, Source domain, Ground), in-depth understanding (Topic,
   Sentiment, Intention, Action and Reason), multi-perspective metaphor
   understanding and comprehensive understanding. We also introduced a
   Prolog+MLLM evaluation method rigorously judging the rationality of
   multi-angle metaphor understanding. Experimental results reveal a
   significant gap between multimodal large language models (MLLMs) and
   humans in understanding visual metaphors, particularly in capturing
   metaphorical features. The number of reasonable interpretations
   generated by these models for visual metaphor images is notably lower
   than human performance, and their ability to interpret multimodal
   metaphor images with rich meanings is limited.},
