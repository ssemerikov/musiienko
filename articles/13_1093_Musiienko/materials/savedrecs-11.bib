@article{ WOS:001470343300008,
Author = {Zhuang, Xudong and Wu, Yu},
Title = {Large Language Models in Corporate Investment: An Analysis of ChatGPT's
   Transformative Applications, Strategic Impacts, and Future Opportunities},
Journal = {IT PROFESSIONAL},
Year = {2025},
Volume = {27},
Number = {2},
Pages = {21-27},
Month = {MAR-APR},
Abstract = {This study presents a framework that analyzes the applications, impacts,
   challenges, and opportunities of large language models in corporate
   investment decision making, with a focus on ChatGPT. The framework
   explores ChatGPT's roles in decision analysis, task assistance, risk
   assessment, and its positive impacts on pre-decision preparation and
   postdecision adjustments. It also examines challenges such as ensuring
   robust data privacy, addressing bias and interpretation issues,
   promoting ethical artificial intelligence (AI) practices, and
   integrating human-AI collaboration. These steps aim to maximize
   ChatGPT's benefits in investment decisions while mitigating risks. The
   study also anticipates future directions and opportunities for ChatGPT
   to further transform corporate investment decision making.},
