   EAIS 2024},
Series = {IEEE Conference on Evolving and Adaptive Intelligence Systems},
Year = {2024},
Pages = {289-296},
Note = {IEEE Conference on Evolving and Adaptive Intelligent Systems (IEEE
   EAIS), Madrid, SPAIN, MAY 23-24, 2024},
Organization = {IEEE},
Abstract = {Natural Language Processing (NLP) has witnessed a paradigm shift with
   Large Language Models (LLMs), yet the static knowledge from pre-training
   can lead to knowledge obsolescence. This study focuses on the dynamic
   relationship between LLMs and evolving knowledge, using GPT-2 as a case
   study. Leveraging an existing framework, we update models with monthly
   Wikipedia dumps and Wikidata probes, addressing the stability-plasticity
   trade-off. We introduce a novel synthetic data generation method for
   experimental control and present SMARTREVIEW, a state-of-the-art
   continual learning method. This work advances understanding and
   methodologies in tackling knowledge obsolescence in evolving language
   models.},
