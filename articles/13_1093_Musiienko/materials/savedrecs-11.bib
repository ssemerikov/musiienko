Note = {19th International Symposium on Applied Computational Intelligence and
   Informatics-SACI-Annual, Timisoara, ROMANIA, MAY 19-24, 2025},
Organization = {Institute of Electrical and Electronics Engineers Inc},
Abstract = {This paper presents the development of a learning assistant utilizing
   Large Language Models (LLMs) to address domain-specific
   question-answering tasks. The process begins with the collection and
   preprocessing of a specialized dataset, followed by its preparation for
   integration with LLMs. A custom scoring system is introduced to evaluate
   and select the model that generates the most accurate responses for a
   sample dataset. The top-performing model is used to generate a refined
   dataset for the fine-tuning process. Multiple models are fine-tuned
   using this enhanced dataset, and their performance is evaluated and
   compared using popular metrics. Additionally, the paper provides an
   overview of major Large Language Models, fine-tuning techniques, and
   evaluation methods, offering valuable insights into the design,
   development, and optimization of LLM-based learning assistants.},
