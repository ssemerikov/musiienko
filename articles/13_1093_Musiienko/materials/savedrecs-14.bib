@article{ WOS:001566091800001,
Author = {Xing, Yongkang and Xiao, Yi and Wang, Xiaoyu and Liang, Yi and Feng,
   Guokai},
Title = {Enhancing Practical Legal Training Through Virtual Reality Moot Court
   Simulations: A Digital Pedagogical Approach for Law Students},
Journal = {INTERNATIONAL JOURNAL OF HUMAN-COMPUTER INTERACTION},
Year = {2025},
Month = {2025 SEP 6},
Abstract = {Undergraduate law students often lack access to moot court facilities
   due to limited availability and cost. This research proposes a virtual
   moot court using virtual reality (VR) to simulate realistic scenarios
   and strengthen legal skills. Combining User-Centered Design (UCD) and
   Project-Based Learning (PBL), the system lets students practice with
   classic cases, emphasizing real-world problem solving. Inspired by
   story-driven game design and prior VR education, an iterative UCD
   process tailors the experience to law students' needs. A comparative
   user test with 60 students assessed effectiveness against traditional
   moot court training. Results indicated improved legal competencies,
   especially for higher-performing students. The study demonstrates VR's
   potential as an accessible, cost-effective alternative to physical moot
   courts, supporting practical legal training and widening access to
   experiential learning for aspiring lawyers. Findings substantiate the VR
   approach as a scalable tool for democratizing experiential legal
   education and preparing students for professional practice, and beyond.},
Publisher = {TAYLOR \& FRANCIS INC},
Address = {530 WALNUT STREET, STE 850, PHILADELPHIA, PA 19106 USA},
Type = {Article; Early Access},
Language = {English},
Affiliation = {Feng, GK (Corresponding Author), Guangdong Univ Finance, Sch Credit Management, Guangzhou, Peoples R China.
   Xing, Yongkang, Guangzhou Maritime Univ, Sch Digital Media \& Interact Design, Guangzhou, Peoples R China.
   Xiao, Yi, Hunan Univ, Sch Design, Changsha, Peoples R China.
