@inproceedings{ WOS:000417330201047,
Author = {Hyder, S. I.},
Editor = {Chova, LG and Martinez, AL and Torres, IC},
Title = {A STRUCTURAL FRAMEWORK FOR ENABLING EXPERIENTIAL LEARNING AND PBL IN
   HIGHER EDUCATION INSTITUTIONS},
Booktitle = {ICERI2016: 9TH INTERNATIONAL CONFERENCE OF EDUCATION, RESEARCH AND
   INNOVATION},
Series = {ICERI Proceedings},
Year = {2016},
Pages = {1261-1270},
Note = {9th Annual International Conference of Education, Research and
   Innovation (iCERi), Seville, SPAIN, NOV 14-16, 2016},
Abstract = {Implementation of active learning in its various forms such as
   experiential learning (ExL), project based learning (PBL) and problem
   based learning often runs into structural constraints of institutions of
   higher education. The constraints relate to legacy requirements of
   accreditation bodies, rigid administrative structures of the
   institutions, and entrenched assumptions about conventional education.
   This paper presents a structural framework for enabling experiential
   learning from the point of view of change management by the academic
   administrators. The structural elements of this framework have been
   identified during the process of implementing experiential learning and
   PBL projects at two institutions of higher learning over the last decade
   in MBA and Bachelor programs of business, engineering and computer
   science involving different types and levels of courses, and across
   different batches of students. The structural elements of this framework
   includes assumptions about the knowledge structure, time structure,
   teaching structure, examination structure, and campus structure
   prevalent in the context of the institutions of higher education and
   their regulatory/accreditation bodies. The thesis of this paper is that
   the extent to which implementation of PBL and experiential learning is
   successful in a degree program depends upon the extent of change from
   conventional assumptions about these structural elements to the enabling
   assumptions of the proposed framework. The change management process
   involves aligning the required curriculum design and administrative
   structures with the necessary buy-in of the faculty, cultural change and
   enabling of other stakeholders. The framework helps in understanding and
   managing this process of change.},
