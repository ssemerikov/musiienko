@inproceedings{ WOS:001551861000010,
Author = {Tang, Xin and Luo, Baoquan and Feng, Qiao},
Editor = {Konomi, S and Streitz, NA},
Title = {Human-Agent Interaction in Batik Digital Learning: Design of an
   AI-Driven Experiential Platform},
Booktitle = {DISTRIBUTED, AMBIENT AND PERVASIVE INTERACTIONS, DAPI 2025, PT I},
Series = {Lecture Notes in Computer Science},
Year = {2025},
Volume = {15802},
Pages = {145-160},
Note = {13th International Conference on Distributed Ambient and Pervasive
   Interactions-DAPI, Goeteborg, SWEDEN, JUN 22-27, 2025},
Abstract = {This research addresses the challenges of low user engagement and
   superficial cultural understanding in the digital inheritance of Batik,
   an Intangible Cultural Heritage, by proposing and implementing a
   Human-Agent collaboration framework based on Experiential Learning
   Theory. Through the development of the ``BatiCloud{''} digital platform,
   we integrated a knowledge-based Agent powered by intelligent Q\&A
   systems and a creative Agent based on Wavelet Models, forming a
   four-stage interaction model of ``Cloud Gathering-Cloud Analysis-Cloud
   Painting-Cloud Creation.{''} The platform utilizes intelligent Q\&A to
   guide cultural understanding, supports pattern innovation design through
   Wavelet Models, and enables the transformation of users' online
   creations into physical products. The research validates the feasibility
   of the ``user-led, Agent-assisted{''} interaction paradigm while
   proposing technical expansion paths based on augmented reality pattern
   recognition and virtual reality craft simulation. This study provides an
   extensible theoretical framework for human-computer interaction design
   in digital cultural heritage preservation, making significant
   contributions to enhancing innovative practices in Intangible Cultural
   Heritage transmission.},
