@inproceedings{ WOS:001582753100017,
Author = {Jin, Huan and He, Yongyi and Zhang, Xiaojie},
Editor = {Jaikaeo, C and Chui, KT and Niramitranon, J and Kaewmanee, W and Ng, KK and Ongkunaruk, P},
Title = {Teaching Design and Practice of Project-based blended Learning Mode in
   Concrete Structure Courses Empowered by Artificial Intelligence},
Booktitle = {2025 INTERNATIONAL SYMPOSIUM ON EDUCATIONAL TECHNOLOGY, ISET},
Series = {International Symposium on Educational Technology},
Year = {2025},
Pages = {88-91},
Note = {2025 International Symposium on Educational Technology-ISET, THAILAND,
   JUL 22-25, 2025},
Abstract = {With the rapid development of artificial intelligence technology, its
   application in the field of education is becoming increasingly
   widespread. This article aims to explore a project-based blended
   learning mode empowered by AI applied to concrete structure courses.
   Based on the analysis of the drawbacks of traditional teaching modes and
   combined with the characteristics of concrete structure courses, a
   combination mode of project-based learning and blended learning is
   proposed, which deeply integrates practice and theory, and improves
   students' engineering practice and innovation abilities. In addition, AI
   technology is proposed to be applied in this teaching mode, which can
   intelligently assist in the construction of teaching resources, student
   self-learning, teaching effectiveness evaluation and feedback, and
   provide personalized learning experiences for students, so as to improve
   teaching efficiency and quality. Through teaching practice, the
   feasibility and effectiveness of the project-based blended learning mode
   in concrete structure courses empowered by AI have been verified. This
   can provide reference and guidance for the teaching reform of related
   courses.},
