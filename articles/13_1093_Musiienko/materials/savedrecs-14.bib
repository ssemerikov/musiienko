@article{ WOS:001092296800001,
Author = {Khan, Asif R. and Thilagam, N. Lakshmi},
Title = {Perception to virtual design studio in the Initiation, realization and
   Reflection Phase: the faculties and students perspective},
Journal = {JOURNAL OF ASIAN ARCHITECTURE AND BUILDING ENGINEERING},
Year = {2024},
Volume = {23},
Number = {4},
Pages = {1165-1183},
Month = {JUL 3},
Abstract = {The study examines virtual design studio pedagogy in regional settings,
   providing a comprehensive understanding of the experiences of faculty
   members and students as they adapted to the virtual design studio due to
   the COVID-19 pandemic. The research focused on B.Arch., an undergraduate
   program affiliated with the University of Calicut, Malappuram, Kerala,
   India. A survey-based cluster sampling approach was made use of. The
   survey questionnaire collected information from faculties and students
   on various aspects of the virtual discourse, and SPSS software was used
   to analyze the data. The Mann-Whitney U test (non-parametric test) was
   employed to compare adaptation and acceptance levels of virtual design
   studios between faculties and students. The results indicated
   differences in adaptation and acceptance levels between the two groups.
   The research also outlines the various stage-wise phases of the virtual
   design studio model. Further explores the future of architecture studio
   pedagogy in a post-Covid scenario, with emphasis on hybrid mode, which
   could be an area for future research.},
