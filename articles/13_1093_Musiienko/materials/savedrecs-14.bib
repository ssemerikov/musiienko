@article{ WOS:000170709800004,
Author = {Zimring, C and Khan, S and Craig, D and Haq, SU and Guzdial, M},
Title = {CoOL Studio: using simple tools to expand the discursive space of the
   design studio},
Journal = {AUTOMATION IN CONSTRUCTION},
Year = {2001},
Volume = {10},
Number = {6},
Pages = {675-685},
Month = {AUG},
Abstract = {Collaborative On-line Studio for Architecture (CoOL Studio) was aimed at
   aiding the architecture studio by: (1) supporting input by distant
   critics; (2) providing access to on-line cases and reference materials;
   (3) encouraging students to be clear and articulate about their
   projects; (4) supporting collaboration among students. The project
   employed a Collaborative Website (CoWeb), which allowed easy creation
   and modification of webpages without any security measures. Students
   posted their designs at several points during the term and six distant
   expert consultants provided critiques. This project demonstrates that a
   relatively simple representation tool, one that allowed students and
   critics to interact on editable webpages, can usefully open up the
   design space of the architecture studio. However, care is needed in
   understanding how computer tools relate to the tasks and rituals of
   interaction that go on in everyday architecture studio pedagogy. (C)
   2001 Elsevier Science B.V. All rights reserved.},
