@inproceedings{ WOS:001220818807014,
Author = {Wang, Jiayu and Zhao, Kang and Ma, Yifeng and Zhang, Shiwei and Zhang,
   Yingya and Shen, Yujun and Zhao, Deli and Zhou, Jingren},
Editor = {Oh, A and Neumann, T and Globerson, A and Saenko, K and Hardt, M and Levine, S},
Title = {FaceComposer: A Unified Model for Versatile Facial Content Creation},
Booktitle = {ADVANCES IN NEURAL INFORMATION PROCESSING SYSTEMS 36 (NEURIPS 2023)},
Series = {Advances in Neural Information Processing Systems},
Year = {2023},
Note = {37th Conference on Neural Information Processing Systems (NeurIPS), New
   Orleans, LA, DEC 10-16, 2023},
Abstract = {This work presents FaceComposer, a unified generative model that
   accomplishes a variety of facial content creation tasks, including
   text-conditioned face synthesis, text-guided face editing, face
   animation etc. Based on the latent diffusion framework, FaceComposer
   follows the paradigm of compositional generation and employs diverse
   face-specific conditions, e.g., Identity Feature and Projected
   Normalized Coordinate Code, to release the model creativity at all
   possible. To support text control and animation, we clean up some
   existing face image datasets and collect around 500 hours of
   talking-face videos, forming a high-quality large-scale multi-modal face
   database. A temporal self-attention module is incorporated into the
   U-Net structure, which allows learning the denoising process on the
   mixture of images and videos. Extensive experiments suggest that our
   approach not only achieves comparable or even better performance than
   state-of-the-arts on each single task, but also facilitates some
   combined tasks with one-time forward, demonstrating its potential in
   serving as a foundation generative model in face domain. We further
   develop an interface such that users can enjoy our one-step service to
   create, edit, and animate their own characters. Code, dataset, model,
   and interface will be made publicly available.},
