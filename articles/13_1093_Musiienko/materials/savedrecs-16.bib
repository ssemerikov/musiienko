@inproceedings{ WOS:000254598700013,
Author = {Healy, John and Janssen, Jeannette and Milios, Evangelos and Aiello,
   William},
Editor = {Aiello, W and Broder, A and Janssen, J and Milios, E},
Title = {Characterization of graphs using degree cores},
Booktitle = {ALGORITHMS AND MODELS FOR THE WEB-GRAPH},
Series = {Lecture Notes in Computer Science},
Year = {2008},
Volume = {4936},
Pages = {137+},
Note = {MEETING ON SOCIAL SCIENCE HISTORY, CHICAGO, IL, NOV 21-24, 1985},
Abstract = {Generative models are often used in modeling real world graphs such as
   the Web graph in order to better understand the processes through which
   these graphs are formed. In order to determine if a graph might have
   been generated by a given model one must compare the features of that
   graph with those generated by the model. We introduce the concept of a
   hierarchical degree core tree as a novel way of summarizing the
   structure of massive graphs. The degree core of level k is the unique
   subgraph of minimal degree k. Hierarchical degree core trees are
   representations of the subgraph relationships between the components of
   the degree core of the graph, ranging over all possible values of k. We
   extract features related to the graph's local structure from these
   hierarchical trees. Using these features, we compare four real world
   graphs (a web graph, a patent citation graph, a co-authorship graph and
   an email graph) against a number of generative models.},
Publisher = {SPRINGER-VERLAG BERLIN},
Address = {HEIDELBERGER PLATZ 3, D-14197 BERLIN, GERMANY},
Type = {Proceedings Paper},
Language = {English},
Affiliation = {Healy, J (Corresponding Author), Dalhousie Univ, Fac Comp Sci, Halifax, NS, Canada.
   Healy, John; Milios, Evangelos, Dalhousie Univ, Fac Comp Sci, Halifax, NS, Canada.
   Janssen, Jeannette, Dalhousie Univ, Dept Math \& Stat, Halifax, NS, Canada.
   Aiello, William, Univ British Columbia, Dept Comp Sci, Vancouver, BC, Canada.},
