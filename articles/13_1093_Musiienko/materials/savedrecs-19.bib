@article{ WOS:001472569400001,
Author = {Dewi, Finita and Justicia, Risty and Putri, Suci Utami and Bayuni, Tia
   Citra},
Title = {Bringing stories to life: enhancing early literacy with digital comics
   and TPACK in pre-service teacher education},
Journal = {JOURNAL OF EARLY CHILDHOOD TEACHER EDUCATION},
Year = {2025},
Month = {2025 APR 24},
Abstract = {This study explores the development of Technological Pedagogical Content
   Knowledge (TPACK) in pre-service early childhood education (ECE)
   teachers through a Learning by Design (LBD) approach, specifically the
   design of digital comics for early literacy instruction. A Design-Based
   Research (DBR) methodology was employed to iteratively design,
   implement, and refine a TPACK-based training program for 27 pre-service
   teachers in Indonesia. Quantitative results from pretest and posttest
   data indicated significant improvements in all TPACK domains,
   particularly Technological Pedagogical Knowledge (TPK) and Technological
   Pedagogical Content Knowledge (TPACK). Qualitative findings from
   observations, interviews, and artifact analysis revealed increased
   teacher confidence in technology use, challenges in aligning technology
   with pedagogy, and enhanced creativity in digital comic designs. The
   study concludes that engaging pre-service teachers in the design of
   digital instructional materials fosters deeper integration of
   technology, pedagogy, and content knowledge, though further support in
   developmentally appropriate pedagogy is needed. Recommendations for
   teacher training programs and future research are discussed.},
