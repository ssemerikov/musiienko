@incollection{ WOS:000360249800008,
Author = {McLoughlin, Catherine},
Editor = {Khine, MS},
Title = {HOW TEACHES DEVELOP TECHNOLOGICAL PEDAGOGICAL CONTENT KNOWLEDGE (TPACK)
   FOR CONTEMPORARY LEARNING ENVIRONMENTS Exemplars of Effective Practice},
Booktitle = {NEW DIRECTIONS IN TECHNOLOGICAL PEDAGOGICAL CONTENT KNOWLEDGE RESEARCH:
   MULTIPLE PERSPECTIVES},
Year = {2015},
Pages = {147-161},
Abstract = {Designed to prepare prospective teachers for effective use of
   technology, teacher education programs now employ the TPACK framework so
   that pre-service teachers effectively plan and implement
   technology-infused learning experiences. While the framework has had
   widespread theoretical support, its application in practice and its
   capacity to provide specific guidance to teachers is debated in the
   literature. One of the issues concerns the complexity of teacher
   knowledge in developing and applying appropriate pedagogies across
   contexts and diverse subject areas. As schools move to digital tools and
   21st century pedagogies, it is considered vital that teachers are not
   only technology savvy and possess digital literacy skills, but they also
   need to be able to teach their subjects by adopting appropriate
   technology integrated pedagogy. Recent calls have reiterated this
   imperative, and a great deal of attention has been given to exploring
   ways to develop TPACK. The focus of this chapter is to illuminate
   successful approaches that have been adopted to develop pre-service
   teachers' technological-pedagogical-content-knowledge, to compare and
   contrast strategies and to signal emerging directions in teacher
   preparation to develop TPACK skills for current learning environments.},
