@inproceedings{ WOS:001491640000087,
Author = {Wang Zuoxu and Liu Jihong and Zheng Lianyu},
Editor = {Anwer, N},
Title = {The Evolution, Framework, and Future of Cognitive Intelligence-enabled
   Product Design},
Booktitle = {32ND CIRP DESIGN CONFERENCE-DESIGN IN A CHANGING WORLD, CIRP DESIGN 2022},
Series = {Procedia CIRP},
Year = {2022},
Volume = {109},
Pages = {526-531},
Note = {32nd Design Conference, Gif-sur-Yvette, FRANCE, MAR 28-30, 2022},
Organization = {Center for Injury Research and Policy (CIRP); Ecole Normale Superieure
   Paris-Saclay},
Abstract = {In recent years, the powerful capabilities of big data and intelligent
   algorithms (e.g., machine learning (ML) and deep learning (DL)) have
   fostered a new product design paradigm called Artificial intelligence
   (AI)-enabled design. Although current AI-enabled design outperforms many
   other classic design methods by effectiveness and efficiency, most of
   its applications are still preliminary AI-based applications, such as
   classification, recognition, and detection. Many domain knowledge and
   design knowledge among historical design cases and designers have not
   been fully recognized and explored. To bridge the semantic gap between
   humans and systems/machines, this study proposed a cognitive
   intelligence-enabled product design (CIPD) framework in which cognitive
   computing serves as the key enabler. To make the vision concrete, this
   study proposes a CIPD framework to illustrate the relationship between
   cognitive intelligence and product design. Meanwhile, the prospective
   human-like capabilities of CIPD and the critical enabling technologies
   are also described. Finally, some potential CIPD industrial applications
   are envisioned. (c) 2022 The Authors. Published by Elsevier B.V.},
