   and Ma, Jimei and Zrubka, Zsombor and Wang, Fei-Yue},
Title = {Interdisciplinary Control Research and Curriculum Development in CPSS: A
   Case Study with 3D Printing and Social Manufacturing},
Journal = {IFAC PAPERSONLINE},
Year = {2025},
Volume = {59},
Number = {7},
Pages = {255-260},
