@inproceedings{ WOS:001554113500003,
Author = {Chang, Shang-Yuan and Tung, Fang-Wu},
Editor = {Stephanidis, C and Antona, M and Ntoa, S and Salvendy, G},
Title = {Exploring the Impact of Generative AI on Product Design Processes and
   Product Designers},
Booktitle = {HCI INTERNATIONAL 2025 POSTERS, HCII 2025, PT VII},
Series = {Communications in Computer and Information Science},
Year = {2025},
Volume = {2528},
Pages = {22-30},
Note = {27th International Conference on Human-Computer Interaction, HCII-HCII,
   Goeteborg, SWEDEN, JUN 22-27, 2025},
Abstract = {The rapid development and widespread application of Artificial
   Intelligence (AI) are profoundly transforming product design processes
   and redefining the role of designers. AI not only accelerates the design
   process but also offers innovative design options, driving iteration and
   personalization. These shifts pose new challenges for designers'
   responsibilities, while also highlighting the importance of education
   and access to changing technology. Although AI is unlikely to completely
   replace designers, collaboration with AI has become an essential and
   inevitable trend. This study sets two key objectives: (1) to examine
   current practices and challenges in AI adoption within design processes
   through interviews with industry leaders, and (2) to evaluate the
   perspectives on generative AI tools in design ideation and
   prototyping-emphasizing the role of education-through a co-creation
   workshop with design students. Research indicates that generative AI
   significantly boosts data collection and design efficiency, yet
   designers' professional expertise remains vital for filtering data and
   leveraging AI-generated outcomes. By harnessing AI for divergent
   thinking in the early design stages, designers can focus on converging
   concepts, allowing them to devote more energy to creativity and
   higher-level strategic design. As technology continues to evolve,
   designers must adapt by formulating clear instructions, refining their
   ability to interact with AI effectively, pursuing continuous education,
   and ensuring they have access to changing technology-alongside the
   critical thinking and problem-solving skills needed to thrive in a
   rapidly shifting industry.},
