@inproceedings{ WOS:001517345700018,
Author = {Ho, Jonathan and Qi, Xiaoyuan and Ma, Yuansheng and Jiang, Fan and
   Zhang, Hongming and Kwan, Joe and Hong, Le},
Editor = {Lafferty, NV and Grunes, H},
Title = {Enhancing Multilayer Process Defect Prediction Accuracy on an Artificial
   Intelligence/Machine Learning (AI/ML) Platform},
Booktitle = {DTCO AND COMPUTATIONAL PATTERNING IV},
Series = {Proceedings of SPIE},
Year = {2025},
Volume = {13425},
Note = {2025 Conference on DTCO and Computational Patterning, San Jose, CA, FEB
   25-28, 2025},
Abstract = {Artificial Intelligence/Machine Learning (AI/ML) multi-layer hotspot
   prediction has been proven useful with design houses to capture
   potential process risky patterns for the most advanced technology modes.
   Since the design houses only have design target layers from the layouts,
   all the signature information used in the AI/ML training for hotspots is
   from the target polygons. Given the fact that most of the hotspots are
   process related with single or multiple layers, and the geometric or
   topological information itself lacks process knowledge from the target
   polygons, the defect prediction could result in high false detection
   counts or miss some real defects. One way to mitigate the problem is to
   design feature vectors which characterize defect patterns and reflect
   the process effect. It is a relatively easy and fast way to successfully
   capture hotspots of interest. To further improve the hotspot detection,
   the process information may be added directly. In this study, physical
   failure analysis (PFA) data trained AI/ML model is generated to include
   process information for hotspot predictions. The PFA trained AI/ML model
   has inputs of PFA data and design layout to fine tune the feature
   vectors for more accurate hotspot prediction. These fine-tuned feature
   vectors contain process information such as on-wafer CDs and etching
   aspects of the patterns that caused defects like line opens or shorts.
   Another perspective of reducing the false alarm is to improve the AI/ML
   model training algorithm. A reinforcement learning model has been
   developed to reduce the false detection from the supervised hotspot
   prediction. The false alarm reduction has been successfully demonstrated
   on a V-x-M-x short hotspot prediction. These enhancements have been
   built on the previously developed feature-based AI/ML platform.},
