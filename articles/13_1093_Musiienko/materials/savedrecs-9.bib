@inproceedings{ WOS:001566302100002,
Author = {Chen, Ching-I},
Editor = {Degen, H and Ntoa, S},
Title = {How Hands-on Experience with Generative AI Shapes Design Students'
   Perspectives on AI's Future Impact},
Booktitle = {ARTIFICIAL INTELLIGENCE IN HCI, AI-HCI 2025, PT III},
Series = {Lecture Notes in Artificial Intelligence},
Year = {2025},
Volume = {15821},
Pages = {22-35},
Note = {6th International Conference on Artificial Intelligence in HCI-AI-HCI,
   Goeteborg, SWEDEN, JUN 22-27, 2025},
Abstract = {This study explores the key aspects that generative AI must address in
   the future within university-level design education. Through
   quantitative and qualitative analysis of data from 32 industrial design
   students, the results indicate that generative AI is most frequently
   utilized during the ideation and early-stage visual representation
   phases. Participants with higher experience levels exhibit a more
   optimistic outlook on the future impact of GenAI, with this difference
   being statistically significant. However, its application remains
   relatively limited in the empathy and testing stages, suggesting the
   need for further integration of generative AI in user research, ethics,
   and diverse contextual applications to fully harness its innovative
   potential in design education and industry. The findings also reveal
   that differences in experience levels have minimal impact on attitudes
   toward adopting generative AI in the design process, though more
   experienced users are more optimistic about its future value.},
