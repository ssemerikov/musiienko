@inproceedings{ WOS:001289066600040,
Author = {Shreya, H. R. and Kumar, Tarun},
Editor = {Senjyu, T and So-In, C and Joshi, A},
Title = {Impact of Artificial Intelligence Tools and Text-to-3D Model Generators
   on Interior Design},
Booktitle = {SMART TRENDS IN COMPUTING AND COMMUNICATIONS, VOL 5, SMARTCOM 2024},
Series = {Lecture Notes in Networks and Systems},
Year = {2024},
Volume = {949},
Pages = {465-478},
Note = {8th Smart Trends in Computing and Communications (SmartCom), Pune,
   INDIA, JAN 12-13, 2024},
Abstract = {The advent of Artificial Intelligence (AI) tools in the present world is
   significantly impacting the field of interior design and architecture.
   This is due to the use of AI tools in 3D modelling and design, through
   computer-aided design (CAD). Therefore, the issue of inclusion of AI
   tools in design education arises, and a method to do so by using AI
   services which are accessible to students is needed. With this objective
   in mind, applications of CAD and AI were explored to gain a basic
   understanding of 3D modeling and prototyping in interior design. This
   led to the realisation that furniture is one of the main components of
   an interior design project. A few categories of furniture were then
   finalised based on their importance in interior design and a dataset was
   created to gather images of real furniture against 3D modelled
   furniture, both AI-generated and self-made. Google Teachable Machine is
   then used to create an image model to categorise furniture and detect
   deformities in the images of furniture in the dataset. The image model
   is then tested, following which a smartphone application implementing
   the above-mentioned concept is proposed, which is publicly accessible.
   The results of the testing elucidated the need for a service to help
   with the scanning of 3D models. This paper seeks to aid design students
   in accessing AI tools and better the design pedagogy by equipping them
   with the skills necessary to master AI tools. This paper also paves the
   way for further innovation in AI tools which are inclusive and
   accessible to students, by developing the proposed solution
   appropriately.},
