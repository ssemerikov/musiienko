@article{ WOS:000935523000001,
Author = {Tanner-Anderson, Sarah and Walker, Ronda},
Title = {Recruiting, retaining, and supporting graduate students of color in PWI
   education and human services programs},
Journal = {MENTORING \& TUTORING},
Year = {2023},
Volume = {31},
Number = {2},
Pages = {271-287},
Month = {MAR 15},
Abstract = {The purpose of this study was to examine the perceptions of alumni of
   color in two graduate programs at a predominantly white institution
   (PWI) in rural Virginia. Through an electronic survey, alumni from a
   communication sciences and disorders (CSD) program and an educational
   leadership program reflected on their perceptions of their program's
   recruitment, retention, and mentorship efforts for graduate students of
   color. Results showed that while graduate students of color in the
   educational leadership graduate program indicated a high level of
   support, some changes may need to be made in the CSD program to address
   the unique needs of graduate students of color. Future directions and
   addressing overarching needs for graduate students of color are
   discussed.},
