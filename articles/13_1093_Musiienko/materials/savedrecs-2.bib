@article{ WOS:001541369700006,
Author = {Duval-Brassard, Penelope and Trudel, Pierre and Trottier, Christiane},
Title = {The graduate student's dilemma: Caught between the inaccessibility of
   systematic reviews and the biases of narrative review},
Journal = {STAPS-SCIENCES ET TECHNIQUES DES ACTIVITES PHYSIQUES ET SPORTIVES},
Year = {2025},
Number = {150},
Pages = {87-103},
Abstract = {The literature review plays a key role in the journey of graduate
   students and impacts their ability to complete their degree within the
   expected timeframe. Unfortunately, graduate students generally lack the
   knowledge and resources required to conduct systematic reviews. At the
   same time, they are told that narrative reviews are not rigorous and are
   more prone to bias. This leaves them with few options to produce
   credible literature reviews. This article describes how a graduate
   student (the first author) used snowballing-a systematic literature
   search technique-to enhance the rigor of a narrative review. It involves
   following the references and citations of relevant papers to identify
   additional studies for the literature review. Reflections on her
   graduate-level experience and the impact of snowballing to date are also
   presented. We conclude with the article's contribution to the graduate
   student journey and to enhancing the student experience of the
   literature review.},
