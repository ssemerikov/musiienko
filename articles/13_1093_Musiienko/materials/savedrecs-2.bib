@article{ WOS:000378459600005,
Author = {Bettinger, Eric P. and Long, Bridget Terry and Taylor, Eric S.},
Title = {When inputs are outputs: The case of graduate student instructors},
Journal = {ECONOMICS OF EDUCATION REVIEW},
Year = {2016},
Volume = {52},
Pages = {63-76},
Month = {JUN},
Abstract = {We examine graduate student teaching as an input to two production
   processes: the education of undergraduates and the development of
   graduate students themselves. Using fluctuations in full-time faculty
   availability as an instrument, we find undergraduates are more likely to
   major in a subject if their first course in the subject was taught by a
   graduate student, a result opposite of estimates that ignore selection.
   Additionally, graduate students who teach more frequently graduate
   earlier and are more likely to subsequently be employed by a college or
   university. (C) 2016 Elsevier Ltd. All rights reserved.},
