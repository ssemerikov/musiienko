Volume = {61},
Pages = {276-281},
Note = {2nd International Conference on Economics and Social Science (ICESS),
   Shenzhen, PEOPLES R CHINA, JUL 29-30, 2014},
Abstract = {The academic anomie and misconduct of graduate students has greatly
   affected the regular academic construction and healthy development of
   scientific innovation. In this paper, the main performances of graduate
   students' academic anomie were summarized, and the root causes including
   objective and subjective factors were analyzed in detail. It is found
   that heteronomy and self-discipline modes both play an important role in
   ruling graduate students' academic morality. Based on this principle,
   academic moral mechanism composed of education, incentive, supervision
   and evaluation aspects was proposed. The construction of academic
   morality system is beneficial to the promotion of graduate students'
   personal abilities and the whole social cultural environment.},
