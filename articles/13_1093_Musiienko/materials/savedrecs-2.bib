@article{ WOS:000702281800001,
Author = {Vasseur, Raychel},
Title = {Multimodal Approaches for Heritage and Second Language Instructor
   Training},
Journal = {LANGUAGES},
Year = {2021},
Volume = {6},
Number = {3},
Month = {SEP},
Abstract = {This piece explores the need to provide better training to graduate
   student instructors by first conducting a needs analysis of current
   graduate students and recent graduate students regarding their
   conceptualizations of writing, multiliteracies, and second (L2) and
   heritage language (HL) pedagogies. Based on this survey, it is evident
   that with just one teaching methods course as the typical training
   graduate student instructors receive it behooves us to implement
   innovative pedagogy in other ways to develop graduate students'
   abilities to navigate new technological tools and reconsider how they
   can teach writing in the L2/HL courses. Based on previous research as
   well as practical experience, this paper discusses several approaches
   for training and preparing graduate students to reconsider their
   preconceived notions of what it means to learn to write in an L2 or HL
   to include more focus on multiliteracies and technological skills to
   prepare students for 21st century communication.},
Publisher = {MDPI},
Address = {ST ALBAN-ANLAGE 66, CH-4052 BASEL, SWITZERLAND},
Type = {Article},
Language = {English},
Affiliation = {Vasseur, R (Corresponding Author), Texas Tech Univ, Dept Class \& Modern Languages \& Literatures, Lubbock, TX 79409 USA.
   Vasseur, Raychel, Texas Tech Univ, Dept Class \& Modern Languages \& Literatures, Lubbock, TX 79409 USA.},
DOI = {10.3390/languages6030143},
Article-Number = {143},
EISSN = {2226-471X},
Keywords = {graduate student training; second language writing; heritage language
