@article{ WOS:000424457200005,
Author = {Brown, Cynthia E. and Sheerin, Kaitlin M.},
Title = {The Role of Graduate Students as Mentors in Health Service Psychology
   Programs},
Journal = {TRAINING AND EDUCATION IN PROFESSIONAL PSYCHOLOGY},
Year = {2018},
Volume = {12},
Number = {1},
Pages = {22-28},
Month = {FEB},
Abstract = {Mentoring relationships in health service psychology (HSP) programs are
   considered by many professionals to be an integral part of student
   training and professional development. Most attention on mentoring
   relationships has focused on mentorship between faculty and students.
   However, emerging literature has suggested that graduate students may
   also act as mentors to other individuals (e.g., undergraduate students,
   postbaccalaureate employees, less experienced graduate students).
   Relationships in which graduate students act as mentors have several
   qualities that may be distinct from mentoring relationships that have
   previously been explored in the mentoring literature (e.g., mentorship
   of students by faculty). In this article, we discuss (a) distinct roles
   and functions of mentoring relationships between graduate students and
   other trainees, (b) how these relationships may develop, (c)
   opportunities for graduate students acting as mentors in the context of
   promoting competencies specific to HSP, (d) considerations for mentoring
   students with diverse identities, and (e) the role of professionals in
   guiding the development of graduate student mentors. Finally, we provide
   recommendations for supporting graduate students who act as mentors.},
