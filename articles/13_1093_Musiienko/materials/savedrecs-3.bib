@inproceedings{ WOS:001601467200013,
Author = {Izani, M. and Fouda, Basma and Assad, A. and Gabr, Mona and Alkhalidi,
   Abdulsamad and Kaleel, A. and Trinh, K. and Abdulla, Dana},
