@inproceedings{ WOS:001443080400146,
Author = {Riazi, Sara and Rooshenas, Pedram},
Book-Group-Author = {ACM},
Title = {LLM-Driven Feedback for Enhancing Conceptual Design Learning in Database
   Systems Courses},
Booktitle = {PROCEEDINGS OF THE 56TH ACM TECHNICAL SYMPOSIUM ON COMPUTER SCIENCE
   EDUCATION, SIGCSE TS 2025, VOL 1},
Year = {2025},
Pages = {1001-1007},
Note = {56th Technical Symposium on Computer Science Education, Pittsburgh, PA,
   FEB 26-MAR 01, 2025},
Abstract = {The integration of LLM-generated feedback into educational settings has
   shown promise in enhancing student learning outcomes. This paper
   presents a novel LLM-driven system that provides targeted feedback for
   conceptual designs in a Database Systems course. The system converts
   student-created entity-relationship diagrams (ERDs) into JSON format,
   allows the student to prune the diagram by isolating a relationship,
   extracts relevant requirements for the selected relationship, and
   utilizes a large language model (LLM) to generate detailed feedback.
   Additionally, the system creates a tailored set of questions and answers
   to further aid student understanding. Our pilot implementation in a
   Database System course demonstrates effective feedback generation that
   helped the students improve their design skills.},
