@article{ WOS:001578024000001,
Author = {Zwolinski, G. and Dubiel, A. and Kaminska, D.},
Title = {Teaching empathy: a comparative analysis of real, virtual, and AI-driven
   methods},
Journal = {INTERACTIVE LEARNING ENVIRONMENTS},
Year = {2025},
Month = {2025 SEP 24},
Abstract = {Empathy is a fundamental skill in universal design -- an approach that
   promotes inclusive, accessible environments for all people, regardless
   of ability, yet the most effective methods for teaching it remain an
   open question. This study examines three distinct approaches to empathy
   training, involving 64 students in a universal design course.
   Participants were divided into three groups, each following a different
   learning path: (1) role-playing experience using external devices such
   as wheelchairs, elderly suits, and pregnancy bellies, (2) a
   laboratory-based approach combining these tools with virtual reality,
   and (3) an AI-supported method, where the process is streamlined through
   AI-driven surveys. The article explores the full empathy training
   process, evaluating the strengths and limitations of each method.
   Additionally, it analyzes pre- and post-training empathy assessments
   completed by students, as well as their qualitative feedback on the
   effectiveness of each approach. The findings provide valuable insights
   into how role-playing, virtual, and AI-driven experiences contribute to
   empathy development.},
