@inproceedings{ WOS:000649734800037,
Author = {Yao, Yunfei and Li, Junfan and Liao, Shizhong},
Editor = {Alamaniotis, M and Pan, S},
Title = {A New Learning Algorithm with General Loss for Neural Networks with
   Random Weights},
