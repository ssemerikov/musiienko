Note = {2025 Region 10 Symposium-TENSYMP-Annual, Christchurch, NEW ZEALAND, JUL
   07-09, 2025},
Organization = {Institute of Electrical and Electronics Engineers Inc},
Abstract = {PhotoSensei introduces a theoretical framework for an AI-powered, mobile
   photography tutor that delivers real-time, personalized feedback by
   integrating lightweight computer-vision encoders with
   large-language-model-driven guidance. We bridge a critical gap in mobile
   learning static tutorials and post-hoc critiques by proposing a hybrid
   CV-LLM loop that (1) analyzes compositional and technical image features
   in situ, (2) generates adaptive natural-language feedback aligned with
   learner proficiency, and (3) embeds reflection-practice cycles to foster
   deeper skill acquisition. Our conceptual model formalizes core
   constructs ``Photography Feedback{''} dimensions and ``Skill-Level
   Personalization{''} and articulates three testable propositions on
   reflection, engagement, and learning transfer. We further delineate a
   four-phase research roadmap, guiding future PoC expansions toward
   empirical validation, reinforcement-learning-driven adaptation, and
   scalable deployment. By situating PhotoSensei at the intersection of
   intelligent tutoring systems and mobile pedagogy, this work advances
   theory in AI-mediated creative education and lays the groundwork for
   next-generation ITS designs in photography and beyond.},
