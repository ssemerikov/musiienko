@inproceedings{ WOS:000870296500025,
Author = {Weichselbraun, Albert and Waldvogel, Roger and Fraefel, Andreas and van
   Schie, Alexander and Kuntschik, Philipp},
Editor = {Rosso, P and Basile, V and Martinez, R and Metais, E and Meziane, F},
Title = {Slot Filling for Extracting Reskilling and Upskilling Options from the
   Web},
Booktitle = {NATURAL LANGUAGE PROCESSING AND INFORMATION SYSTEMS (NLDB 2022)},
