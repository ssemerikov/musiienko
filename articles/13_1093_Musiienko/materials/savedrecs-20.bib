@article{ WOS:000477788900004,
Author = {Colombo, Emilio and Mercorio, Fabio and Mezzanzanica, Mario},
Title = {AI meets labor market: Exploring the link between automation and skills},
Journal = {INFORMATION ECONOMICS AND POLICY},
Year = {2019},
Volume = {47},
Number = {SI},
Pages = {27-37},
Month = {JUN},
Abstract = {This paper develops a set of innovative tools for labor market
   intelligence by applying machine learning techniques to web vacancies on
   the Italian labor market. Our approach allows to calculate, for each
   occupation, the different types of skills required by the market
   alongside a set of relevant variables such as region, sector, education
   and level of experience. We construct a taxonomy for skills and map it
   into the recently developed ESCO classification system. We subsequently
   develop measures of the relevance of soft and hard skills and we analyze
   their detailed composition. We apply the dataset constructed to the
   debate on computerization of work. We show that soft and digital skills
   are related to the probability of automation of a given occupation and
   we shed some light on the complementarity/substitutability of hard and
   soft skills. (C) 2019 Elsevier B.V. All rights reserved.},
