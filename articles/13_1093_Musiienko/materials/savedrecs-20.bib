@incollection{ WOS:001553222100004,
Author = {Brown, Phillip and Tholen, Gerbrand},
Editor = {Purser, G and Delbridge, R and Helfen, M and Pekarek, A},
Title = {EMPLOYABILITY, AUTOMATION AND THE FUTURE OF WORK IN THE US AND UK: AN
   OCCUPATIONAL ANALYSIS},
Booktitle = {EMPLOYABILITY: Ideology, Policy, and Practice},
Series = {Research in the Sociology of Work},
Year = {2025},
Volume = {37},
Pages = {67-95},
Abstract = {This chapter explores the impact of digital technologies on
   employability and the future of work. It addresses three areas of
   contention within the literature. First, it examines whether new
   technologies are causing significant technological unemployment. Second,
   it discusses the idea of the `hollowing out' of middle-level jobs due to
   technological change. Third, it evaluates the conventional `labour
   scarcity' view, which assumes that technological change will lead to a
   growing demand for university-educated workers. Based on occupational
   trend data, it challenges the `labour scarcity' view of employability
   and advocates a job scarcity approach, emphasizing a structural mismatch
   between available jobs and workforce skills. The chapter urges
   policymakers to focus more on job quality rather than continuing the
   search for `supply side' solutions. Generative AI and related
   technologies are not skills-biased as previously assumed, as there is
   little evidence of an accelerated demand for `knowledge' workers, and
   much will depend on how firms balance efficiency with human-centric
   employment practices.},
