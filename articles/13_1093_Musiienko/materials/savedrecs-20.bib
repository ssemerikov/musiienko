Type = {Article},
Language = {English},
Affiliation = {SRIDHAR, V (Corresponding Author), Int Inst Informat Technol Bangalore, Bangalore, Karnataka, India.
   UPRETI, A. R. V. I. N. D.; SRIDHAR, V., Int Inst Informat Technol Bangalore, Bangalore, Karnataka, India.},
