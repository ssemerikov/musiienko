@article{ WOS:001086878000013,
Author = {Kumari, Vandana and Shukla, Balvinder and Duggal, Taranjeet},
Title = {Beyond technical know how: A bibliometric study of future soft skills},
Journal = {JOURNAL OF STATISTICS AND MANAGEMENT SYSTEMS},
Year = {2023},
Volume = {26},
Number = {5, SI},
Pages = {1133-1146},
Month = {JUL},
Note = {8th Annual Global Leadership Research Conference (GLRC), Amity Business
   Sch, Noida, INDIA, MAR 13-15, 2023},
Abstract = {Background: To encourage economic and social progress, it is crucial to
   develop human capital and associate skill sets with job requirements.
   Due to the shift in necessary competencies and abilities, there is a
   discrepancy between what businesses demand and the professional profiles
   that are accessible in the labor market. COVID-19 has been the catalyst
   in accelerating the pace of change and affecting the job market. This
   has led to huge demand for upskilling and reskilling.
   Design/methodology/approach: A thorough study was carried out on 127
   articles obtained from the SCOPUS database. These articles were
   collected by searching for the keyword ``future skills{''} in Scopus.
   The study employed bibliometric techniques, to present a comprehensive
   view of future skill research, encompassing performance analysis and
   science mapping.
   Findings: The findings indicate a recent surge in research focused on
   future skills, and countries like United states and United Kingdom
   leading in this area. However, there remains ample room for further
   investigation, as outlined in this study. The majority of research on
   future skills is primarily associated with social sciences, business,
   management, and accounting disciplines.
   Originality/value: This paper stands out due to its pioneering approach
   in offering valuable insights into the present state of research on
   future skills. Additionally, by employing bibliometric analysis, it
   offers recommendations for potential future paths.},
