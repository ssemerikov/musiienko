@article{ WOS:001327503900001,
Author = {Conde-Ruiz, Jose Ignacio and Fernandez, Juan Jose Ganuza and Garcia,
   Manuel and Lanzon, Carlos Victoria},
Title = {AI and Digital Technology: Gender Gaps in Higher Education},
Journal = {CESIFO ECONOMIC STUDIES},
Year = {2024},
Month = {2024 OCT 7},
Abstract = {This article examines gender gaps in higher education in Spain in the
   context of technological advancements, particularly digitalization and
   artificial intelligence (AI). First, analyzing descriptive Spanish data
   we identify significant disparities, with women overrepresented in
   health-related fields and underrepresented in STEM (Science, Technology,
   Engineering and Mathematics) disciplines. This imbalance is concerning
   as STEM fields offer better employment prospects and higher salaries.
   Then, we analyze university degrees' exposure to technological change
   through routine task intensity (RTI) and AI exposure indices, as well as
   a novel index of exposure to emerging digital technologies from 2015 to
   2024. Our findings show that women are more enrolled in degrees with
   higher RTI, prone to automation, and less in degrees with higher AI
   exposure, likely to benefit from technological advancements. This
   suggests technological change could widen existing labor market gender
   gaps. To address this, we recommend policies to boost female
   participation in STEM fields and adapt educational curricula to reduce
   routine tasks and enhance AI complementarities, ensuring equitable labor
   market outcomes amid technological change. (JEL codes: I23, I26, J16,
   J24).},
